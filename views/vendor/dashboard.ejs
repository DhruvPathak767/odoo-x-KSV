<%- include('../partials/header') %>

<div class="dashboard-hero" style="margin-bottom: 2rem;">
    <div class="glass-card dashboard-welcome-card" style="padding: 2.5rem 2rem;">
        <div class="grid-overlay"></div>
        <div class="badge-wrapper">
            <span class="badge" style="border-color: rgba(236,72,153,0.25); color: var(--color-primary);">
                <span class="badge-pulse" style="background-color: var(--color-primary);"></span>
                Supplier Console Active
            </span>
        </div>
        <h1 style="font-size: 2.5rem; margin-bottom: 0.5rem;">
            <%= vendor.company_name %>
        </h1>
        <p style="color: var(--color-text-secondary); max-width: 600px;">
            Supplier Account: <strong><%= vendor.contact_person %></strong> (<%= vendor.category %>)
        </p>
        
        <div style="display: flex; gap: 1rem; margin-top: 1.5rem; flex-wrap: wrap;">
            <a href="/vendor/rfqs" class="btn btn-primary btn-glow" style="font-size: 0.85rem; padding: 0.6rem 1.25rem;">
                View Assigned RFQs
            </a>
            <a href="/vendor/po" class="btn btn-secondary" style="font-size: 0.85rem; padding: 0.6rem 1.25rem; border-radius: 8px;">
                View Purchase Orders
            </a>
        </div>
    </div>
</div>

<% if (locals.statusNotApproved) { %>
    <div class="glass-card" style="padding: 3rem 2rem; text-align: center;">
        <div class="feature-icon gold-icon-glow" style="margin: 0 auto 1.5rem auto;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
        </div>
        <h3 style="font-size: 1.5rem; margin-bottom: 1rem;">Application Review In Progress</h3>
        <p style="color: var(--color-text-secondary); max-width: 500px; margin: 0 auto;">
            Your vendor registration application is currently under review by our procurement officers. 
            Once your account status is verified, you will receive invitation requests and bidding access.
        </p>
    </div>
<% } else { %>
    <!-- Active Vendor Dashboard -->
    <div class="metrics-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.5rem; margin-bottom: 2rem;">
        <div class="glass-card" style="padding: 1.75rem 1.5rem; min-height: 140px; display: flex; flex-direction: column; justify-content: space-between;">
            <div style="display: flex; justify-content: space-between; align-items: center;">
                <span style="font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-muted); font-family: 'Outfit'; font-weight: 600;">Assigned RFQs</span>
                <span class="metric-icon" style="background: rgba(99, 102, 241, 0.15); color: #818cf8; padding: 0.35rem 0.5rem; border-radius: 8px;">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline></svg>
                </span>
            </div>
            <div>
                <div style="font-size: 2.5rem; font-weight: 800; color: #ffffff;"><%= metrics.rfqs %></div>
                <span style="font-size: 0.75rem; color: var(--color-text-muted);">Active invitations to bid</span>
            </div>
        </div>

        <div class="glass-card" style="padding: 1.75rem 1.5rem; min-height: 140px; display: flex; flex-direction: column; justify-content: space-between;">
            <div style="display: flex; justify-content: space-between; align-items: center;">
                <span style="font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-muted); font-family: 'Outfit'; font-weight: 600;">Submitted Quotes</span>
                <span class="metric-icon" style="background: rgba(236, 72, 153, 0.15); color: var(--color-primary); padding: 0.35rem 0.5rem; border-radius: 8px;">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                </span>
            </div>
            <div>
                <div style="font-size: 2.5rem; font-weight: 800; color: #ffffff;"><%= metrics.quotes %></div>
                <span style="font-size: 0.75rem; color: var(--color-text-muted);">Bids logged in database</span>
            </div>
        </div>

        <div class="glass-card" style="padding: 1.75rem 1.5rem; min-height: 140px; display: flex; flex-direction: column; justify-content: space-between;">
            <div style="display: flex; justify-content: space-between; align-items: center;">
                <span style="font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-muted); font-family: 'Outfit'; font-weight: 600;">Approved Quotes</span>
                <span class="metric-icon" style="background: rgba(16, 185, 129, 0.15); color: var(--color-success); padding: 0.35rem 0.5rem; border-radius: 8px;">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                </span>
            </div>
            <div>
                <div style="font-size: 2.5rem; font-weight: 800; color: #ffffff;"><%= metrics.approved %></div>
                <span style="font-size: 0.75rem; color: var(--color-success);">Bids won and finalized</span>
            </div>
        </div>

        <div class="glass-card" style="padding: 1.75rem 1.5rem; min-height: 140px; display: flex; flex-direction: column; justify-content: space-between;">
            <div style="display: flex; justify-content: space-between; align-items: center;">
                <span style="font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-muted); font-family: 'Outfit'; font-weight: 600;">Purchase Orders</span>
                <span class="metric-icon" style="background: rgba(99, 102, 241, 0.15); color: #818cf8; padding: 0.35rem 0.5rem; border-radius: 8px;">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline></svg>
                </span>
            </div>
            <div>
                <div style="font-size: 2.5rem; font-weight: 800; color: #ffffff;"><%= metrics.pos %></div>
                <span style="font-size: 0.75rem; color: var(--color-text-secondary);">Active contract agreements</span>
            </div>
        </div>
    </div>

    <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 2rem; margin-top: 2rem;">
        <!-- Left Panel: Assigned RFQs Table -->
        <div class="glass-card" style="padding: 1.5rem;">
            <h3 style="font-size: 1.2rem; margin-bottom: 1.25rem; display: flex; align-items: center; gap: 0.5rem;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
                Available Invitations to Bid
            </h3>
            
            <% if (recentRFQs.length === 0) { %>
                <p style="color: var(--color-text-muted); text-align: center; padding: 2rem 0;">No active RFQ invites assigned to your company.</p>
            <% } else { %>
                <div style="overflow-x: auto;">
                    <table style="width: 100%; border-collapse: collapse; text-align: left; font-size: 0.9rem;">
                        <thead>
                            <tr style="border-bottom: 1px solid rgba(255,255,255,0.06); color: var(--color-text-muted);">
                                <th style="padding: 0.75rem 0.5rem;">Title</th>
                                <th style="padding: 0.75rem 0.5rem;">Category</th>
                                <th style="padding: 0.75rem 0.5rem;">Deadline</th>
                                <th style="padding: 0.75rem 0.5rem; text-align: right;">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% recentRFQs.forEach(rfq => { %>
                                <tr style="border-bottom: 1px solid rgba(255,255,255,0.03);">
                                    <td style="padding: 0.75rem 0.5rem;">
                                        <strong style="color: #ffffff;"><%= rfq.title %></strong>
                                    </td>
                                    <td style="padding: 0.75rem 0.5rem;"><%= rfq.category %></td>
                                    <td style="padding: 0.75rem 0.5rem; font-family: monospace;"><%= new Date(rfq.deadline).toLocaleDateString() %></td>
                                    <td style="padding: 0.75rem 0.5rem; text-align: right;">
                                        <a href="/vendor/rfqs/<%= rfq.id %>" class="btn btn-secondary" style="padding: 0.4rem 0.8rem; font-size: 0.75rem; border-radius: 8px;">View details & Bid</a>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } %>
        </div>

        <!-- Right Panel: Activity feeds -->
        <div class="glass-card" style="padding: 1.5rem;">
            <h3 style="font-size: 1.2rem; margin-bottom: 1.25rem;">Live Activity Feed</h3>
            <div style="display: flex; flex-direction: column; gap: 1rem;">
                <% activities.forEach(act => { %>
                    <div style="background: rgba(255,255,255,0.01); border: 1px solid rgba(255,255,255,0.03); padding: 0.75rem 1rem; border-radius: 10px;">
                        <strong style="color: #ffffff; font-size: 0.85rem; display: block;"><%= act.title %></strong>
                        <span style="font-size: 0.75rem; color: var(--color-text-secondary); display: block; margin-top: 0.25rem;"><%= act.description %></span>
                        <span style="font-size: 0.65rem; color: var(--color-text-muted); font-family: monospace; display: block; margin-top: 0.25rem;"><%= act.time %></span>
                    </div>
                <% }) %>
            </div>
        </div>
    </div>
<% } %>

<%- include('../partials/footer') %>
