<%- include('../partials/header') %>

<div style="margin-bottom: 2rem;">
    <h1 style="font-size: 2.2rem; margin-bottom: 0.5rem;">Assigned RFQs</h1>
    <p style="color: var(--color-text-secondary);">Review RFQ invitations and submit quotation bids before deadlines.</p>
</div>

<div class="glass-card" style="padding: 2rem;">
    <% if (rfqs.length === 0) { %>
        <div style="text-align: center; padding: 3rem 0; color: var(--color-text-muted);">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom: 1rem; color: var(--color-text-muted);"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
            <p>No invitations to bid have been issued to your company yet.</p>
        </div>
    <% } else { %>
        <div style="overflow-x: auto;">
            <table style="width: 100%; border-collapse: collapse; text-align: left; font-size: 0.95rem;">
                <thead>
                    <tr style="border-bottom: 1px solid rgba(255,255,255,0.08); color: var(--color-text-muted);">
                        <th style="padding: 1rem 0.5rem;">RFQ Ref #</th>
                        <th style="padding: 1rem 0.5rem;">Title</th>
                        <th style="padding: 1rem 0.5rem;">Category</th>
                        <th style="padding: 1rem 0.5rem;">Deadline</th>
                        <th style="padding: 1rem 0.5rem; text-align: right;">Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% rfqs.forEach(rfq => { %>
                        <tr style="border-bottom: 1px solid rgba(255,255,255,0.03); transition: background-color 0.2s;">
                            <td style="padding: 1rem 0.5rem; font-family: monospace; font-weight: 700; color: var(--color-primary);">
                                RFQ-<%= String(rfq.id).padStart(4, '0') %>
                            </td>
                            <td style="padding: 1rem 0.5rem;">
                                <strong style="color: #ffffff;"><%= rfq.title %></strong>
                            </td>
                            <td style="padding: 1rem 0.5rem;"><%= rfq.category %></td>
                            <td style="padding: 1rem 0.5rem; font-family: monospace;"><%= new Date(rfq.deadline).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %></td>
                            <td style="padding: 1rem 0.5rem; text-align: right;">
                                <a href="/vendor/rfqs/<%= rfq.id %>" class="btn btn-secondary" style="padding: 0.5rem 1rem; font-size: 0.8rem; border-radius: 8px;">
                                    Bidding details &rarr;
                                </a>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    <% } %>
</div>

<%- include('../partials/footer') %>
