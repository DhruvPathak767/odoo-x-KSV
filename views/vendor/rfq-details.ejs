<%- include('../partials/header') %>

<div style="margin-bottom: 2rem;">
    <a href="/vendor/rfqs" style="color: var(--color-primary); font-size: 0.9rem; display: inline-flex; align-items: center; gap: 0.25rem; margin-bottom: 0.75rem;">
        &larr; Back to Assigned RFQs
    </a>
    <h1 style="font-size: 2.2rem; margin-bottom: 0.5rem;"><%= rfq.title %></h1>
    <p style="color: var(--color-text-secondary);">Ref: <strong style="color: var(--color-primary);">RFQ-<%= String(rfq.id).padStart(4, '0') %></strong> | Category: <strong><%= rfq.category %></strong></p>
</div>

<div style="display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 2rem; align-items: start;">
    <!-- LEFT: RFQ DETAILS & LINE ITEMS -->
    <div style="display: flex; flex-direction: column; gap: 2rem;">
        <div class="glass-card" style="padding: 2rem;">
            <h3 style="font-size: 1.2rem; border-bottom: 1px solid rgba(255,255,255,0.08); padding-bottom: 0.5rem; margin-bottom: 1rem; color: var(--color-primary);">Guidelines & Details</h3>
            <p style="color: var(--color-text-secondary); line-height: 1.6; white-space: pre-line; font-size: 0.95rem;">
                <%= rfq.description %>
            </p>
            
            <div style="display: flex; gap: 2rem; margin-top: 1.5rem; flex-wrap: wrap;">
                <div style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.04); padding: 0.75rem 1.25rem; border-radius: 10px;">
                    <span style="font-size: 0.7rem; color: var(--color-text-muted); display: block; text-transform: uppercase;">Deadline Date</span>
                    <strong style="color: #ffffff; font-family: monospace; font-size: 0.95rem;"><%= new Date(rfq.deadline).toLocaleDateString() %></strong>
                </div>
                <div style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.04); padding: 0.75rem 1.25rem; border-radius: 10px;">
                    <span style="font-size: 0.7rem; color: var(--color-text-muted); display: block; text-transform: uppercase;">RFQ Status</span>
                    <span class="module-status-pill status-active-badge" style="margin-top: 0.15rem; font-size: 0.65rem; padding: 0.15rem 0.5rem;"><%= rfq.status %></span>
                </div>
                <% if (rfq.attachment) { %>
                <div style="background: rgba(99,102,241,0.05); border: 1px solid rgba(99,102,241,0.2); padding: 0.75rem 1.25rem; border-radius: 10px;">
                    <span style="font-size: 0.7rem; color: var(--color-text-muted); display: block; text-transform: uppercase;">Attachment</span>
                    <a href="/uploads/<%= rfq.attachment %>" target="_blank" style="color: var(--color-primary); font-size: 0.9rem; font-weight: 600; text-decoration: none; display: inline-flex; align-items: center; gap: 0.25rem; margin-top: 0.15rem;">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"></path></svg>
                        Download SOW
                    </a>
                </div>
                <% } %>
            </div>
        </div>

        <div class="glass-card" style="padding: 2rem;">
            <h3 style="font-size: 1.2rem; border-bottom: 1px solid rgba(255,255,255,0.08); padding-bottom: 0.5rem; margin-bottom: 1rem; color: var(--color-primary);">Required Line Items</h3>
            <div style="overflow-x: auto;">
                <table style="width: 100%; border-collapse: collapse; text-align: left; font-size: 0.9rem;">
                    <thead>
                        <tr style="border-bottom: 1px solid rgba(255,255,255,0.06); color: var(--color-text-muted);">
                            <th style="padding: 0.75rem 0.5rem;">Item Description</th>
                            <th style="padding: 0.75rem 0.5rem; text-align: center;">Required Quantity</th>
                            <th style="padding: 0.75rem 0.5rem; text-align: right;">Target Price</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% items.forEach(item => { %>
                            <tr style="border-bottom: 1px solid rgba(255,255,255,0.03);">
                                <td style="padding: 0.75rem 0.5rem;">
                                    <strong style="color: #ffffff;"><%= item.item_name %></strong>
                                </td>
                                <td style="padding: 0.75rem 0.5rem; text-align: center;"><%= item.quantity %></td>
                                <td style="padding: 0.75rem 0.5rem; text-align: right; font-family: monospace;">
                                    <%= item.target_price ? '$' + parseFloat(item.target_price).toLocaleString() : 'N/A' %>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- RIGHT: QUOTATION SUBMISSION FORM -->
    <div class="glass-card" style="padding: 2rem;">
        <h3 style="font-size: 1.2rem; border-bottom: 1px solid rgba(255,255,255,0.08); padding-bottom: 0.5rem; margin-bottom: 1.5rem; color: var(--color-primary);">
            <%= existingQuote ? 'Modify Bidding Proposal' : 'Submit Quotation Proposal' %>
        </h3>

        <!-- Alert placeholder -->
        <div id="alert-container">
            <% if (existingQuote) { %>
                <div class="alert-banner alert-banner-success">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                    <span>Proposal Active. Status: <strong><%= existingQuote.status %></strong></span>
                </div>
            <% } %>
        </div>

        <% 
            const isDeadlinePassed = new Date(rfq.deadline) < new Date();
            const isDisabled = isDeadlinePassed || (existingQuote && (existingQuote.status === 'Approved' || existingQuote.status === 'Rejected'));
        %>

        <% if (isDeadlinePassed) { %>
            <div class="alert-banner alert-banner-error" style="margin-bottom: 1rem;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
                <span>Bidding Closed: Bidding deadline has passed.</span>
            </div>
        <% } %>

        <form class="auth-form" id="rfq-quote-form" method="POST" action="/vendor/rfqs/<%= rfq.id %>/quote" style="gap: 1.25rem;">
            <input type="hidden" name="token" value="<%= rfq.id %>">
            <div class="form-group">
                <label for="price" class="form-label">Total Proposed Price ($) *</label>
                <input type="number" id="price" name="price" class="form-control" placeholder="12500" required step="0.01" min="0.01" <%= isDisabled ? 'disabled' : '' %> value="<%= existingQuote ? existingQuote.price : '' %>">
            </div>

            <div class="form-group">
                <label for="delivery_days" class="form-label">Delivery Timeline (Days) *</label>
                <input type="number" id="delivery_days" name="delivery_days" class="form-control" placeholder="15" required min="1" <%= isDisabled ? 'disabled' : '' %> value="<%= existingQuote ? existingQuote.delivery_days : '' %>">
            </div>

            <div class="form-group">
                <label for="warranty_months" class="form-label">Warranty Coverage (Months)</label>
                <input type="number" id="warranty_months" name="warranty_months" class="form-control" placeholder="12" min="0" <%= isDisabled ? 'disabled' : '' %> value="<%= existingQuote ? existingQuote.warranty_months : '0' %>">
            </div>

            <div class="form-group">
                <label for="remarks" class="form-label">Proposal Notes / Technical Specifications</label>
                <textarea id="remarks" name="remarks" class="form-control" rows="4" placeholder="Mention shipping details, validity terms..." <%= isDisabled ? 'disabled' : '' %>><%= existingQuote ? existingQuote.remarks : '' %></textarea>
            </div>

            <div class="form-group">
                <label for="quote-attachment" class="form-label">Technical Proposal/Spec Sheet <span style="color: var(--color-text-muted); font-size: 0.8rem;">(Allowed: .pdf, .docx, .xlsx, .png, .jpg, .jpeg)</span></label>
                <input type="file" id="quote-attachment" name="attachment" class="form-control" style="padding: 0.5rem; background: rgba(0,0,0,0.25);" <%= isDisabled ? 'disabled' : '' %>>
                <% if (existingQuote && existingQuote.attachment) { %>
                    <div style="margin-top: 0.5rem; font-size: 0.85rem;">
                        <span style="color: var(--color-text-muted);">Current:</span>
                        <a href="/uploads/<%= existingQuote.attachment %>" target="_blank" style="color: var(--color-primary); text-decoration: none; font-weight: bold; display: inline-flex; align-items: center; gap: 0.25rem;">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"></path></svg>
                            <%= existingQuote.attachment %>
                        </a>
                    </div>
                <% } %>
            </div>

            <% if (!isDisabled) { %>
                <button type="submit" class="btn btn-primary btn-glow btn-auth-submit" id="btn-submit" style="margin-top: 1rem;">
                    <span><%= existingQuote ? 'Update Bidding Proposal' : 'Submit Quotation' %></span>
                </button>
            <% } else { %>
                <button type="button" class="btn btn-secondary btn-auth-submit" style="margin-top: 1rem; cursor: not-allowed;" disabled>
                    <span>Bidding Disabled</span>
                </button>
            <% } %>
        </form>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const form = document.getElementById('rfq-quote-form');
        const alertContainer = document.getElementById('alert-container');

        if (form) {
            form.addEventListener('submit', async (e) => {
                e.preventDefault();

                const submitBtn = document.getElementById('btn-submit');
                const btnSpan = submitBtn ? submitBtn.querySelector('span') : null;
                const originalText = btnSpan ? btnSpan.textContent : '';

                const price = parseFloat(document.getElementById('price').value);
                const delivery_days = parseInt(document.getElementById('delivery_days').value, 10);
                const warranty_months = parseInt(document.getElementById('warranty_months').value, 10) || 0;
                const remarks = document.getElementById('remarks').value.trim();

                if (submitBtn) {
                    submitBtn.disabled = true;
                    if (btnSpan) btnSpan.textContent = 'Submitting Proposal...';
                    submitBtn.style.opacity = '0.7';
                }

                const showAlert = (message, type = 'error') => {
                    if (alertContainer) {
                        alertContainer.innerHTML = `
                            <div class="alert-banner alert-banner-${type}" style="margin-bottom: 1rem;">
                                ${type === 'success' 
                                    ? '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>'
                                    : '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>'
                                }
                                <span>${message}</span>
                            </div>
                        `;
                    }
                };

                // Construct FormData object
                const formData = new FormData();
                formData.append('price', price);
                formData.append('delivery_days', delivery_days);
                formData.append('warranty_months', warranty_months);
                formData.append('remarks', remarks);
                
                const fileInput = document.getElementById('quote-attachment');
                if (fileInput && fileInput.files[0]) {
                    formData.append('attachment', fileInput.files[0]);
                }

                try {
                    const response = await fetch(form.action, {
                        method: 'POST',
                        body: formData
                    });

                    const result = await response.json();

                    if (response.ok && result.success) {
                        showAlert(result.message, 'success');
                        setTimeout(() => {
                            window.location.href = result.redirectUrl || '/vendor/rfqs';
                        }, 1500);
                    } else {
                        showAlert(result.message || 'Error submitting quotation.', 'error');
                        if (submitBtn) {
                            submitBtn.disabled = false;
                            submitBtn.style.opacity = '1';
                            if (btnSpan) btnSpan.textContent = originalText;
                        }
                    }
                } catch (err) {
                    console.error(err);
                    showAlert('Network error. Check connection and try again.', 'error');
                    if (submitBtn) {
                        submitBtn.disabled = false;
                        submitBtn.style.opacity = '1';
                        if (btnSpan) btnSpan.textContent = originalText;
                    }
                }
            });
        }
    });
</script>

<%- include('../partials/footer') %>
