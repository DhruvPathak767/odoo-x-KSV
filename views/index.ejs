<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <meta name="description" content="Manage vendors, RFQs, quotations, approvals, purchase orders, and invoices from one centralized, highly automated platform. Modern ERP built for enterprise procurement.">
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <!-- Main Stylesheet -->
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <!-- Premium Noise & Spotlight overlays -->
    <div class="noise-overlay"></div>
    <div class="global-spotlight"></div>

    <!-- Background Particle Canvas -->
    <canvas id="particles-canvas"></canvas>

    <!-- Background Glow Orbs -->
    <div class="glow-orb glow-orb-1"></div>
    <div class="glow-orb glow-orb-2"></div>
    <div class="glow-orb glow-orb-3"></div>

    <!-- HEADER / NAVIGATION -->
    <header class="navbar" id="navbar">
        <div class="nav-container">
            <a href="#" class="logo-group" id="nav-logo">
                <svg class="logo-icon" width="36" height="36" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <defs>
                        <linearGradient id="logo-grad" x1="0%" y1="0%" x2="100%" y2="100%">
                            <stop offset="0%" stop-color="#ec4899" />
                            <stop offset="100%" stop-color="#6366f1" />
                        </linearGradient>
                    </defs>
                    <path d="M20 70 L40 30 L60 30 L80 70" stroke="url(#logo-grad)" stroke-width="10" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M30 55 L70 55" stroke="#ec4899" stroke-width="8" stroke-linecap="round"/>
                    <circle cx="50" cy="30" r="8" fill="#ec4899" class="logo-dot" />
                </svg>
                <span class="logo-text">Vendor<span>Bridge</span></span>
            </a>

            <nav class="nav-menu" id="nav-menu">
                <a href="#features" class="nav-link">Features</a>
                <a href="#workflow" class="nav-link">Workflow</a>
                <a href="#benefits" class="nav-link">Benefits</a>
                <a href="#contact" class="nav-link">Contact</a>
            </nav>

            <div class="nav-actions">
                <a href="#contact" class="btn btn-primary btn-nav">Request Demo</a>
                <button class="mobile-toggle" id="mobile-toggle" aria-label="Toggle Navigation">
                    <span class="bar"></span>
                    <span class="bar"></span>
                    <span class="bar"></span>
                </button>
            </div>
        </div>
    </header>

    <!-- MOBILE OVERLAY MENU -->
    <div class="mobile-menu-overlay" id="mobile-menu-overlay">
        <nav class="mobile-nav-links">
            <a href="#features" class="mobile-nav-link">Features</a>
            <a href="#workflow" class="mobile-nav-link">Workflow</a>
            <a href="#benefits" class="mobile-nav-link">Benefits</a>
            <a href="#contact" class="mobile-nav-link">Contact</a>
            <a href="#contact" class="btn btn-primary btn-mobile-nav">Request Demo</a>
        </nav>
    </div>

    <main>
        <!-- HERO SECTION -->
        <section class="hero-section" id="hero">
            <!-- Hero Abstract Glowing Bridge Background Graphic -->
            <div class="hero-bg-graphics">
                <div class="hero-grid-mesh"></div>
                <svg class="hero-bridge-svg" viewBox="0 0 1000 400" xmlns="http://www.w3.org/2000/svg">
                    <defs>
                        <linearGradient id="bridge-grad" x1="0%" y1="0%" x2="100%" y2="0%">
                            <stop offset="0%" stop-color="#ec4899" stop-opacity="0.05" />
                            <stop offset="50%" stop-color="#a855f7" stop-opacity="0.7" />
                            <stop offset="100%" stop-color="#6366f1" stop-opacity="0.05" />
                        </linearGradient>
                        <filter id="bridge-glow" x="-20%" y="-20%" width="140%" height="140%">
                            <feGaussianBlur stdDeviation="8" result="blur" />
                            <feComposite in="SourceGraphic" in2="blur" operator="over" />
                        </filter>
                    </defs>
                    <!-- Curved bridge beams -->
                    <path d="M 100 350 Q 500 120, 900 350" stroke="url(#bridge-grad)" stroke-width="5" fill="none" stroke-linecap="round" filter="url(#bridge-glow)" />
                    <path d="M 100 375 Q 500 170, 900 375" stroke="url(#bridge-grad)" stroke-width="2.5" fill="none" stroke-dasharray="12 12" />
                    
                    <!-- Vertical hanger cords -->
                    <line x1="200" y1="288" x2="200" y2="356" stroke="rgba(168, 85, 247, 0.15)" stroke-width="1" />
                    <line x1="300" y1="238" x2="300" y2="362" stroke="rgba(168, 85, 247, 0.15)" stroke-width="1" />
                    <line x1="400" y1="202" x2="400" y2="367" stroke="rgba(168, 85, 247, 0.15)" stroke-width="1" />
                    <line x1="500" y1="185" x2="500" y2="369" stroke="rgba(168, 85, 247, 0.15)" stroke-width="1" />
                    <line x1="600" y1="202" x2="600" y2="367" stroke="rgba(168, 85, 247, 0.15)" stroke-width="1" />
                    <line x1="700" y1="238" x2="700" y2="362" stroke="rgba(168, 85, 247, 0.15)" stroke-width="1" />
                    <line x1="800" y1="288" x2="800" y2="356" stroke="rgba(168, 85, 247, 0.15)" stroke-width="1" />

                    <!-- Moving light rays traveling across the bridge beam -->
                    <circle r="6" fill="#ec4899" filter="url(#glow)">
                        <animateMotion dur="7s" repeatCount="indefinite" path="M 100 350 Q 500 120, 900 350" />
                    </circle>
                    <circle r="4.5" fill="#6366f1" filter="url(#glow)">
                        <animateMotion dur="5.5s" repeatCount="indefinite" path="M 900 350 Q 500 120, 100 350" />
                    </circle>
                </svg>
            </div>
            <div class="container hero-container">
                <div class="hero-content reveal-fade-up">
                    <div class="badge-wrapper">
                        <span class="badge">
                            <span class="badge-pulse"></span>
                            Modern Procurement ERP
                        </span>
                    </div>
                    <h1 class="hero-title">
                        Procurement Made <span class="gradient-text">Intelligent</span>
                    </h1>
                    <p class="hero-subtitle">
                        Manage vendors, RFQs, quotations, approvals, purchase orders and invoices from one centralized, automated platform. Streamline collaboration and control costs effortlessly.
                    </p>
                    <div class="hero-actions">
                        <a href="#contact" class="btn btn-primary btn-glow">Request Demo</a>
                        <a href="#workflow" class="btn btn-secondary">
                            <span>Explore Workflow</span>
                            <svg class="btn-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <line x1="5" y1="12" x2="19" y2="12"></line>
                                <polyline points="12 5 19 12 12 19"></polyline>
                            </svg>
                        </a>
                    </div>
                </div>

                <div class="hero-visual reveal-fade-up">
                    <div class="mockup-container">
                        <!-- Card 1: Vendors list (Glassmorphism) -->
                        <div class="mockup-card card-vendors float-1" data-tilt>
                            <div class="card-header">
                                <div class="card-title-group">
                                    <span class="card-icon cyan-icon">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                                    </span>
                                    <span>Active Vendors</span>
                                </div>
                                <span class="card-badge bg-cyan-glow">524 Connected</span>
                            </div>
                            <div class="card-body">
                                <div class="list-item">
                                    <div class="item-info">
                                        <span class="item-name">Apex Global Tech</span>
                                        <span class="item-meta">Electronics • tier-1</span>
                                    </div>
                                    <div class="item-status status-verified">Verified</div>
                                </div>
                                <div class="list-item">
                                    <div class="item-info">
                                        <span class="item-name">Zenith Logistics</span>
                                        <span class="item-meta">Freight • tier-1</span>
                                    </div>
                                    <div class="item-status status-verified">Verified</div>
                                </div>
                                <div class="list-item">
                                    <div class="item-info">
                                        <span class="item-name">Nova Chemicals Inc.</span>
                                        <span class="item-meta">Raw Materials</span>
                                    </div>
                                    <div class="item-status status-pending">Pending Review</div>
                                </div>
                            </div>
                        </div>

                        <!-- Card 2: RFQ Status Gauge (Glassmorphism) -->
                        <div class="mockup-card card-rfq float-2" data-tilt>
                            <div class="card-header">
                                <div class="card-title-group">
                                    <span class="card-icon purple-icon">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                                    </span>
                                    <span>Active RFQs</span>
                                </div>
                            </div>
                            <div class="card-body flex-row">
                                <div class="gauge-container">
                                    <svg class="gauge" width="70" height="70" viewBox="0 0 36 36">
                                        <path class="gauge-bg" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="rgba(255,255,255,0.05)" stroke-width="3"/>
                                        <path class="gauge-fill" stroke-dasharray="78, 100" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="url(#cyan-purple-grad)" stroke-width="3" stroke-linecap="round"/>
                                        <defs>
                                            <linearGradient id="cyan-purple-grad" x1="0%" y1="0%" x2="100%" y2="100%">
                                                <stop offset="0%" stop-color="#ec4899" />
                                                <stop offset="100%" stop-color="#a855f7" />
                                            </linearGradient>
                                        </defs>
                                    </svg>
                                    <span class="gauge-text">78%</span>
                                </div>
                                <div class="gauge-stats">
                                    <div class="stat-row"><span class="bullet cyan"></span> 18 Sent</div>
                                    <div class="stat-row"><span class="bullet purple"></span> 14 Quotes Recv</div>
                                </div>
                            </div>
                        </div>

                        <!-- Card 3: Quotation Compare / Savings (Glassmorphism) -->
                        <div class="mockup-card card-quote float-3" data-tilt>
                            <div class="card-header">
                                <div class="card-title-group">
                                    <span class="card-icon green-icon">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
                                    </span>
                                    <span>Quote Analysis</span>
                                </div>
                            </div>
                            <div class="card-body">
                                <div class="quote-bar-group">
                                    <div class="bar-label">Apex Tech (Lowest)</div>
                                    <div class="bar-container">
                                        <div class="bar-fill green-bar" style="width: 55%;"></div>
                                        <span class="bar-value">$12.5k</span>
                                    </div>
                                </div>
                                <div class="quote-bar-group">
                                    <div class="bar-label">Nexus Systems</div>
                                    <div class="bar-container">
                                        <div class="bar-fill red-bar" style="width: 85%;"></div>
                                        <span class="bar-value">$19.2k</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Card 4: Actionable Approvals (Glassmorphism) -->
                        <div class="mockup-card card-approvals float-4" data-tilt>
                            <div class="card-header">
                                <div class="card-title-group">
                                    <span class="card-icon yellow-icon">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                                    </span>
                                    <span>Approval Pending</span>
                                </div>
                            </div>
                            <div class="card-body">
                                <p class="card-desc">RFQ #2041 — Material Supply Order</p>
                                <div class="approval-meta">
                                    <span class="price-tag">$42,900</span>
                                    <div class="approval-actions">
                                        <button class="btn-action reject" aria-label="Reject">
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                                        </button>
                                        <button class="btn-action approve" aria-label="Approve">
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Card 5: Purchase Orders Step (Glassmorphism) -->
                        <div class="mockup-card card-po float-5" data-tilt>
                            <div class="card-header">
                                <div class="card-title-group">
                                    <span class="card-icon blue-icon">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
                                    </span>
                                    <span>PO #0492 Tracking</span>
                                </div>
                                <span class="card-badge bg-blue-glow">In Transit</span>
                            </div>
                            <div class="card-body">
                                <div class="stepper">
                                    <div class="step step-complete">
                                        <div class="step-dot"></div>
                                        <span class="step-label">Draft</span>
                                    </div>
                                    <div class="step step-complete">
                                        <div class="step-dot"></div>
                                        <span class="step-label">Approved</span>
                                    </div>
                                    <div class="step step-active">
                                        <div class="step-dot"></div>
                                        <span class="step-label">Dispatched</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Card 6: Invoices & Spend Trends (Glassmorphism) -->
                        <div class="mockup-card card-invoices float-6" data-tilt>
                            <div class="card-header">
                                <div class="card-title-group">
                                    <span class="card-icon gold-icon">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2" ry="2"></rect><line x1="12" y1="4" x2="12" y2="20"></line><line x1="2" y1="12" x2="22" y2="12"></line></svg>
                                    </span>
                                    <span>Monthly Procurement Spend</span>
                                </div>
                                <span class="card-trend text-green">+4.2%</span>
                            </div>
                            <div class="card-body">
                                <div class="chart-container">
                                    <svg class="spend-chart" width="100%" height="45" viewBox="0 0 100 30" preserveAspectRatio="none">
                                        <defs>
                                            <linearGradient id="chart-glow" x1="0%" y1="0%" x2="0%" y2="100%">
                                                <stop offset="0%" stop-color="rgba(236, 72, 153, 0.4)" />
                                                <stop offset="100%" stop-color="rgba(236, 72, 153, 0)" />
                                            </linearGradient>
                                        </defs>
                                        <path d="M 0 25 Q 15 15, 30 18 T 60 5 T 90 10 L 100 8 L 100 30 L 0 30 Z" fill="url(#chart-glow)"/>
                                        <path d="M 0 25 Q 15 15, 30 18 T 60 5 T 90 10 L 100 8" fill="none" stroke="#ec4899" stroke-width="2" stroke-linecap="round"/>
                                        <!-- Interactive floating nodes -->
                                        <circle cx="60" cy="5" r="2.5" fill="#6366f1" class="pulse-dot" />
                                    </svg>
                                </div>
                                <div class="spend-summary">
                                    <div class="spend-val">$184,200</div>
                                    <div class="spend-lbl">3-Way Match Verified</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- WORKFLOW SECTION -->
        <section class="workflow-section" id="workflow">
            <div class="container">
                <div class="section-header reveal-fade-up">
                    <span class="section-tag">Continuous Stream</span>
                    <h2 class="section-title">Automated Lifecycle</h2>
                    <p class="section-subtitle">Watch standard purchasing workflows progress seamlessly. Our engine automates checkpoints and guarantees audit compliance automatically.</p>
                </div>

                <div class="workflow-visualizer reveal-fade-up">
                    <!-- Workflow Steps Container -->
                    <div class="workflow-steps">
                        <!-- Step 1: RFQ -->
                        <div class="workflow-step active-step" data-step="1">
                            <div class="step-icon-outer">
                                <div class="step-icon">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                                </div>
                                <div class="step-num-badge">1</div>
                            </div>
                            <h3>RFQ</h3>
                            <p>Generate & broadcast structured requirement lists to matching vendors.</p>
                        </div>

                        <!-- Connector Line 1 -->
                        <div class="workflow-connector desktop-only">
                            <svg class="connector-svg" width="100%" height="20" viewBox="0 0 100 20" preserveAspectRatio="none">
                                <line x1="0" y1="10" x2="100" y2="10" stroke="rgba(255,255,255,0.05)" stroke-width="2"/>
                                <line x1="0" y1="10" x2="100" y2="10" stroke="#ec4899" stroke-width="2" class="glowing-line" id="line-1"/>
                            </svg>
                        </div>

                        <!-- Step 2: Quotation -->
                        <div class="workflow-step" data-step="2">
                            <div class="step-icon-outer">
                                <div class="step-icon">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                                </div>
                                <div class="step-num-badge">2</div>
                            </div>
                            <h3>Quotation</h3>
                            <p>Recieve vendor responses, structured side-by-side automatically.</p>
                        </div>

                        <!-- Connector Line 2 -->
                        <div class="workflow-connector desktop-only">
                            <svg class="connector-svg" width="100%" height="20" viewBox="0 0 100 20" preserveAspectRatio="none">
                                <line x1="0" y1="10" x2="100" y2="10" stroke="rgba(255,255,255,0.05)" stroke-width="2"/>
                                <line x1="0" y1="10" x2="100" y2="10" stroke="#6366f1" stroke-width="2" class="glowing-line" id="line-2"/>
                            </svg>
                        </div>

                        <!-- Step 3: Approval -->
                        <div class="workflow-step" data-step="3">
                            <div class="step-icon-outer">
                                <div class="step-icon">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                                </div>
                                <div class="step-num-badge">3</div>
                            </div>
                            <h3>Approval</h3>
                            <p>Trigger conditional digital approval pipelines for key stakeholders.</p>
                        </div>

                        <!-- Connector Line 3 -->
                        <div class="workflow-connector desktop-only">
                            <svg class="connector-svg" width="100%" height="20" viewBox="0 0 100 20" preserveAspectRatio="none">
                                <line x1="0" y1="10" x2="100" y2="10" stroke="rgba(255,255,255,0.05)" stroke-width="2"/>
                                <line x1="0" y1="10" x2="100" y2="10" stroke="#7928ca" stroke-width="2" class="glowing-line" id="line-3"/>
                            </svg>
                        </div>

                        <!-- Step 4: Purchase Order -->
                        <div class="workflow-step" data-step="4">
                            <div class="step-icon-outer">
                                <div class="step-icon">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                                </div>
                                <div class="step-num-badge">4</div>
                            </div>
                            <h3>Purchase Order</h3>
                            <p>Automated PO dispatch directly to the winning supplier's system.</p>
                        </div>

                        <!-- Connector Line 4 -->
                        <div class="workflow-connector desktop-only">
                            <svg class="connector-svg" width="100%" height="20" viewBox="0 0 100 20" preserveAspectRatio="none">
                                <line x1="0" y1="10" x2="100" y2="10" stroke="rgba(255,255,255,0.05)" stroke-width="2"/>
                                <line x1="0" y1="10" x2="100" y2="10" stroke="#ec4899" stroke-width="2" class="glowing-line" id="line-4"/>
                            </svg>
                        </div>

                        <!-- Step 5: Invoice -->
                        <div class="workflow-step" data-step="5">
                            <div class="step-icon-outer">
                                <div class="step-icon">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2" ry="2"></rect><line x1="12" y1="4" x2="12" y2="20"></line><line x1="2" y1="12" x2="22" y2="12"></line></svg>
                                </div>
                                <div class="step-num-badge">5</div>
                            </div>
                            <h3>Invoice</h3>
                            <p>Execute digital 3-way match, ledger entry, and payment queues.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- FEATURES GRID SECTION -->
        <section class="features-section" id="features">
            <div class="container">
                <div class="section-header reveal-fade-up">
                    <span class="section-tag">Modular Power</span>
                    <h2 class="section-title">Built for Complex Workloads</h2>
                    <p class="section-subtitle">Eliminate friction from supply chain operations. Every component operates in complete harmony.</p>
                </div>

                <div class="features-grid">
                    <!-- Card 1: Vendor Management -->
                    <div class="glass-card feature-card reveal-fade-up" data-tilt id="card-vendor-mgmt">
                        <div class="card-glow-element"></div>
                        <div class="feature-icon cyan-icon-glow">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                        </div>
                        <h3>Vendor Management</h3>
                        <p>Maintain verified profiles, review scorecards, track performance metrics, and compliance standings inside a secure repository.</p>
                        
                        <!-- Micro simulation -->
                        <div class="micro-sim vendor-sim">
                            <div class="compliance-circle-outer">
                                <svg class="compliance-svg" width="70" height="70" viewBox="0 0 36 36">
                                    <path class="comp-bg" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="rgba(255,255,255,0.03)" stroke-width="3"/>
                                    <path class="comp-fill" stroke-dasharray="0, 100" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="url(#logo-grad)" stroke-width="3" stroke-linecap="round"/>
                                </svg>
                                <div class="compliance-value">0%</div>
                            </div>
                            <span class="sim-label">Tier-1 Compliance Score</span>
                        </div>
                    </div>

                    <!-- Card 2: RFQ Creation -->
                    <div class="glass-card feature-card reveal-fade-up" data-tilt id="card-rfq-mgmt">
                        <div class="card-glow-element"></div>
                        <div class="feature-icon purple-icon-glow">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                        </div>
                        <h3>RFQ Creation</h3>
                        <p>Generate highly custom request templates, add target specs, automatically enforce timeline rules, and bulk-dispatch requests instantly.</p>
                        
                        <!-- Micro simulation -->
                        <div class="micro-sim rfq-sim">
                            <div class="terminal-header">
                                <span class="terminal-dot red"></span>
                                <span class="terminal-dot yellow"></span>
                                <span class="terminal-dot green"></span>
                                <span class="terminal-title">rfq_engine.sh</span>
                            </div>
                            <div class="terminal-body">
                                <div class="terminal-prompt">> <span class="typing-text">rfq --dispatch --all</span></div>
                                <div class="terminal-log"></div>
                            </div>
                        </div>
                    </div>

                    <!-- Card 3: Quotation Comparison -->
                    <div class="glass-card feature-card reveal-fade-up" data-tilt id="card-quote-mgmt">
                        <div class="card-glow-element"></div>
                        <div class="feature-icon green-icon-glow">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"></line><line x1="12" y1="20" x2="12" y2="4"></line><line x1="6" y1="20" x2="6" y2="14"></line></svg>
                        </div>
                        <h3>Quotation Comparison</h3>
                        <p>View side-by-side matrices instantly. Use automated scoring to rank bids based on price, delivery time, and history metrics.</p>
                        
                        <!-- Micro simulation -->
                        <div class="micro-sim quote-sim">
                            <div class="bar-chart-sim">
                                <div class="chart-sim-bar" style="--target-h: 70%;">
                                    <div class="bar-inner"></div>
                                    <span class="bar-lbl">Zenith</span>
                                </div>
                                <div class="chart-sim-bar lowest-bar" style="--target-h: 30%;">
                                    <div class="bar-inner"></div>
                                    <span class="bar-lbl">Apex (L1)</span>
                                </div>
                                <div class="chart-sim-bar" style="--target-h: 90%;">
                                    <div class="bar-inner"></div>
                                    <span class="bar-lbl">Nexus</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Card 4: Approval Workflow -->
                    <div class="glass-card feature-card reveal-fade-up" data-tilt id="card-approval-mgmt">
                        <div class="card-glow-element"></div>
                        <div class="feature-icon blue-icon-glow">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                        </div>
                        <h3>Approval Workflow</h3>
                        <p>Deploy conditional approval triggers (e.g. by department or dollar amounts) and gather digital signatures via audit-locked logs.</p>
                        
                        <!-- Micro simulation -->
                        <div class="micro-sim approval-sim">
                            <div class="approval-slider-track">
                                <div class="approval-slider-handle">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"></polyline></svg>
                                </div>
                                <span class="slider-text">Swipe to Approve</span>
                            </div>
                            <div class="approval-success-stamp">APPROVED</div>
                        </div>
                    </div>

                    <!-- Card 5: Purchase Orders -->
                    <div class="glass-card feature-card reveal-fade-up" data-tilt id="card-po-mgmt">
                        <div class="card-glow-element"></div>
                        <div class="feature-icon gold-icon-glow">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
                        </div>
                        <h3>Purchase Orders</h3>
                        <p>Generate PO contracts automatically from winning quotations. Track fulfillment, dispatch logistics, and receipt confirmations.</p>
                        
                        <!-- Micro simulation -->
                        <div class="micro-sim po-sim">
                            <div class="po-path-visual">
                                <div class="path-node node-1 active-node">
                                    <span class="node-dot"></span>
                                    <span class="node-text">Issued</span>
                                </div>
                                <div class="path-line">
                                    <div class="path-line-fill"></div>
                                </div>
                                <div class="path-node node-2">
                                    <span class="node-dot"></span>
                                    <span class="node-text">Accepted</span>
                                </div>
                                <div class="path-line">
                                    <div class="path-line-fill"></div>
                                </div>
                                <div class="path-node node-3">
                                    <span class="node-dot"></span>
                                    <span class="node-text">Transit</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Card 6: Invoice Management -->
                    <div class="glass-card feature-card reveal-fade-up" data-tilt id="card-invoice-mgmt">
                        <div class="card-glow-element"></div>
                        <div class="feature-icon red-icon-glow">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2" ry="2"></rect><line x1="12" y1="4" x2="12" y2="20"></line><line x1="2" y1="12" x2="22" y2="12"></line></svg>
                        </div>
                        <h3>Invoice Management</h3>
                        <p>Enforce strict 3-way matches across POs, goods-received notes, and invoices to flag anomalies and process accounts payable fast.</p>
                        
                        <!-- Micro simulation -->
                        <div class="micro-sim invoice-sim">
                            <div class="matching-ledger">
                                <div class="ledger-row match-1">
                                    <span class="match-checkbox"></span>
                                    <span>Purchase Order (PO #0492)</span>
                                </div>
                                <div class="ledger-row match-2">
                                    <span class="match-checkbox"></span>
                                    <span>Goods Received (GRN #1128)</span>
                                </div>
                                <div class="ledger-row match-3">
                                    <span class="match-checkbox"></span>
                                    <span>Vendor Invoice (INV-992)</span>
                                </div>
                            </div>
                            <div class="matching-status">MATCHING LEDGER...</div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- STATISTICS SECTION -->
        <section class="stats-section" id="benefits">
            <div class="container">
                <div class="stats-grid glass-card">
                    <div class="stat-item reveal-fade-up">
                        <div class="stat-num" data-val="500">0</div>
                        <div class="stat-label">Vendors Onboarded</div>
                    </div>
                    <div class="stat-item reveal-fade-up">
                        <div class="stat-num" data-val="10000">0</div>
                        <div class="stat-label">RFQs Processed</div>
                    </div>
                    <div class="stat-item reveal-fade-up">
                        <div class="stat-num" data-val="95">0</div>
                        <div class="stat-label">Approval Efficiency</div>
                    </div>
                    <div class="stat-item reveal-fade-up">
                        <div class="stat-num" data-val="50">0</div>
                        <div class="stat-label">Faster Procurement</div>
                    </div>
                </div>
            </div>
        </section>

        <!-- WHY VENDORBRIDGE SECTION -->
        <section class="why-section">
            <div class="container">
                <div class="section-header reveal-fade-up">
                    <span class="section-tag">Enterprise Architecture</span>
                    <h2 class="section-title">End-to-End Synergy</h2>
                    <p class="section-subtitle">Legacy supply chain models involve fragmented databases. VendorBridge anchors the entire cycle inside a single real-time ledger.</p>
                </div>

                <div class="network-viz-container reveal-fade-up">
                    <!-- SVG Network Diagram -->
                    <svg class="network-svg-bg" viewBox="0 0 1000 500" xmlns="http://www.w3.org/2000/svg">
                        <defs>
                            <linearGradient id="cyan-glow-grad" x1="0%" y1="0%" x2="100%" y2="100%">
                                <stop offset="0%" stop-color="#ec4899" />
                                <stop offset="100%" stop-color="#6366f1" />
                            </linearGradient>
                            <linearGradient id="purple-glow-grad" x1="0%" y1="0%" x2="100%" y2="100%">
                                <stop offset="0%" stop-color="#a855f7" />
                                <stop offset="100%" stop-color="#ec4899" />
                            </linearGradient>
                            <!-- Filter for intense glow -->
                            <filter id="glow" x="-20%" y="-20%" width="140%" height="140%">
                                <feGaussianBlur stdDeviation="6" result="blur" />
                                <feComposite in="SourceGraphic" in2="blur" operator="over" />
                            </filter>
                        </defs>

                        <!-- Central Hub Lines -->
                        <g class="network-lines">
                            <!-- Left to Hub -->
                            <path d="M 150 150 Q 300 200, 500 250" stroke="url(#cyan-glow-grad)" stroke-width="2" fill="none" class="dash-path" />
                            <path d="M 150 250 L 500 250" stroke="url(#cyan-glow-grad)" stroke-width="2" fill="none" class="dash-path" />
                            <path d="M 150 350 Q 300 300, 500 250" stroke="url(#cyan-glow-grad)" stroke-width="2" fill="none" class="dash-path" />

                            <!-- Hub to Right -->
                            <path d="M 500 250 Q 700 200, 850 150" stroke="url(#purple-glow-grad)" stroke-width="2" fill="none" class="dash-path" />
                            <path d="M 500 250 L 850 250" stroke="url(#purple-glow-grad)" stroke-width="2" fill="none" class="dash-path" />
                            <path d="M 500 250 Q 700 300, 850 350" stroke="url(#purple-glow-grad)" stroke-width="2" fill="none" class="dash-path" />
                        </g>

                        <!-- Glowing Flowing Particles -->
                        <circle r="4" fill="#ec4899" filter="url(#glow)">
                            <animateMotion dur="4s" repeatCount="indefinite" path="M 150 150 Q 300 200, 500 250" />
                        </circle>
                        <circle r="4" fill="#ec4899" filter="url(#glow)">
                            <animateMotion dur="3s" repeatCount="indefinite" path="M 150 250 L 500 250" />
                        </circle>
                        <circle r="4" fill="#ec4899" filter="url(#glow)">
                            <animateMotion dur="5s" repeatCount="indefinite" path="M 150 350 Q 300 300, 500 250" />
                        </circle>
                        <circle r="4" fill="#ff0080" filter="url(#glow)">
                            <animateMotion dur="4s" repeatCount="indefinite" path="M 500 250 Q 700 200, 850 150" />
                        </circle>
                        <circle r="4" fill="#ff0080" filter="url(#glow)">
                            <animateMotion dur="3.5s" repeatCount="indefinite" path="M 500 250 L 850 250" />
                        </circle>
                        <circle r="4" fill="#ff0080" filter="url(#glow)">
                            <animateMotion dur="4.8s" repeatCount="indefinite" path="M 500 250 Q 700 300, 850 350" />
                        </circle>
                    </svg>

                    <!-- DOM Node Elements placed over SVG coordinates -->
                    <div class="net-node node-vendor" style="top: 30%; left: 15%;">
                        <div class="node-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle></svg></div>
                        <span>Vendor Database</span>
                    </div>
                    <div class="net-node node-rfq" style="top: 50%; left: 15%;">
                        <div class="node-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline></svg></div>
                        <span>RFQs Sent</span>
                    </div>
                    <div class="net-node node-quote" style="top: 70%; left: 15%;">
                        <div class="node-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg></div>
                        <span>Quotation Matrices</span>
                    </div>

                    <!-- Center Hub -->
                    <div class="net-node node-hub" style="top: 50%; left: 50%;">
                        <div class="hub-radar"></div>
                        <div class="hub-radar-2"></div>
                        <div class="hub-hologram-ring hub-hologram-ring-1"></div>
                        <div class="hub-hologram-ring hub-hologram-ring-2"></div>
                        <div class="node-icon hub-icon">
                            <svg class="pulse-icon" width="28" height="28" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M20 70 L40 30 L60 30 L80 70" stroke="#ec4899" stroke-width="12" stroke-linecap="round" stroke-linejoin="round"/>
                                <path d="M30 55 L70 55" stroke="#ec4899" stroke-width="9" stroke-linecap="round"/>
                            </svg>
                        </div>
                        <span class="hub-title">VendorBridge ERP</span>
                    </div>

                    <!-- Right nodes -->
                    <div class="net-node node-approval" style="top: 30%; left: 85%;">
                        <div class="node-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg></div>
                        <span>Approvals Ledger</span>
                    </div>
                    <div class="net-node node-po" style="top: 50%; left: 85%;">
                        <div class="node-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13"></rect><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg></div>
                        <span>Purchase Orders</span>
                    </div>
                    <div class="net-node node-invoice" style="top: 70%; left: 85%;">
                        <div class="node-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2" ry="2"></rect><line x1="12" y1="4" x2="12" y2="20"></line></svg></div>
                        <span>Ledger Invoices</span>
                    </div>
                </div>
            </div>
        </section>

        <!-- CTA SECTION -->
        <section class="cta-section" id="contact">
            <!-- Glowing background mesh -->
            <div class="cta-glow"></div>
            <div class="container cta-container reveal-fade-up">
                <div class="glass-card cta-card">
                    <div class="grid-overlay"></div>
                    <h2>Transform Procurement Operations</h2>
                    <p>Automate procurement workflows, reduce order cycles by 50%, and maintain complete transparency across all vendors. Set up a secure sandbox environment today.</p>
                    <div class="cta-form-container">
                        <form class="cta-form" onsubmit="event.preventDefault(); alert('Demo requested! We will reach out within 2 hours.');">
                            <input type="email" placeholder="Enter your business email" required aria-label="Business Email">
                            <button type="submit" class="btn btn-primary btn-glow">Get Started</button>
                        </form>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <!-- FOOTER -->
    <footer class="footer">
        <div class="container footer-container">
            <div class="footer-brand">
                <a href="#" class="logo-group">
                    <svg width="28" height="28" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <defs>
                            <linearGradient id="footer-logo-grad" x1="0%" y1="0%" x2="100%" y2="100%">
                                <stop offset="0%" stop-color="#ec4899" />
                                <stop offset="100%" stop-color="#6366f1" />
                            </linearGradient>
                        </defs>
                        <path d="M20 70 L40 30 L60 30 L80 70" stroke="url(#footer-logo-grad)" stroke-width="10" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M30 55 L70 55" stroke="#ec4899" stroke-width="8" stroke-linecap="round"/>
                    </svg>
                    <span class="logo-text">Vendor<span>Bridge</span></span>
                </a>
                <p class="footer-desc">Procurement & Vendor Management ERP. Built for 2026 enterprise supply chain operations.</p>
            </div>
            <div class="footer-links-grid">
                <div class="footer-col">
                    <h4>Product</h4>
                    <a href="#features">Features</a>
                    <a href="#workflow">Workflow</a>
                    <a href="#benefits">Benefits</a>
                </div>
                <div class="footer-col">
                    <h4>Legal</h4>
                    <a href="#">Privacy Policy</a>
                    <a href="#">Terms of Service</a>
                    <a href="#">Security Audit</a>
                </div>
                <div class="footer-col">
                    <h4>Contact</h4>
                    <a href="mailto:info@vendorbridge.com">info@vendorbridge.com</a>
                    <a href="#">Support Portal</a>
                    <a href="#">Partner Program</a>
                </div>
            </div>
        </div>
        <div class="container footer-bottom">
            <p>&copy; <%= year %> VendorBridge Inc. All rights reserved. Built with precision for modern logistics.</p>
        </div>
    </footer>

    <!-- Main JavaScript File -->
    <script src="/script.js"></script>
</body>
</html>
