<%- include('../partials/header') %>

<div style="margin-bottom: 2rem;">
    <h1 style="font-size: 2.2rem; margin-bottom: 0.5rem;">Manage Vendors</h1>
    <p style="color: var(--color-text-secondary);">Review supplier onboarding applications, verify GST/tax registries, and toggle partnership status.</p>
</div>

<!-- Success/Error Banners -->
<% if (success) { %>
    <div class="alert-banner alert-banner-success" style="margin-bottom: 1.5rem;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
        <span>
            <% if (success === 'vendor_approved') { %>
                Vendor onboarding application approved! Account has been verified and activated.
            <% } else if (success === 'vendor_rejected') { %>
                Vendor onboarding application has been rejected.
            <% } else { %>
                <%= success %>
            <% } %>
        </span>
    </div>
<% } %>

<% if (error) { %>
    <div class="alert-banner alert-banner-error" style="margin-bottom: 1.5rem;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
        <span><%= error === 'vendor_not_found' ? 'Supplier profile was not found.' : error %></span>
    </div>
<% } %>

<!-- 1. PENDING APPLICATIONS CARD -->
<div class="glass-card" style="padding: 2rem; margin-bottom: 2rem;">
    <h3 style="font-size: 1.25rem; margin-bottom: 1.25rem; display: flex; align-items: center; gap: 0.5rem; color: #fbbf24;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
        Pending Onboarding Applications (<%= pending.length %>)
    </h3>
    
    <% if (pending.length === 0) { %>
        <p style="color: var(--color-text-muted); text-align: center; padding: 2rem 0;">No pending supplier applications to review. All caught up!</p>
    <% } else { %>
        <div style="overflow-x: auto;">
            <table style="width: 100%; border-collapse: collapse; text-align: left; font-size: 0.9rem;">
                <thead>
                    <tr style="border-bottom: 1px solid rgba(255,255,255,0.06); color: var(--color-text-muted);">
                        <th style="padding: 0.75rem 0.5rem;">Company Info</th>
                        <th style="padding: 0.75rem 0.5rem;">GST / Tax Number</th>
                        <th style="padding: 0.75rem 0.5rem;">Category</th>
                        <th style="padding: 0.75rem 0.5rem;">Contact Person</th>
                        <th style="padding: 0.75rem 0.5rem;">Location</th>
                        <th style="padding: 0.75rem 0.5rem; text-align: right;">Evaluation Decisions</th>
                    </tr>
                </thead>
                <tbody>
                    <% pending.forEach(vnd => { %>
                        <tr style="border-bottom: 1px solid rgba(255,255,255,0.03);">
                            <td style="padding: 0.75rem 0.5rem;">
                                <strong style="color: #ffffff; display: block;"><%= vnd.company_name %></strong>
                                <span style="font-size: 0.75rem; color: var(--color-text-muted);"><%= vnd.email %></span>
                            </td>
                            <td style="padding: 0.75rem 0.5rem; font-family: monospace; font-weight: bold; color: var(--color-primary);"><%= vnd.gst_number %></td>
                            <td style="padding: 0.75rem 0.5rem;"><%= vnd.category %></td>
                            <td style="padding: 0.75rem 0.5rem;">
                                <span style="display: block; font-weight: 500;"><%= vnd.contact_person %></span>
                                <span style="font-size: 0.75rem; color: var(--color-text-muted);"><%= vnd.phone %></span>
                            </td>
                            <td style="padding: 0.75rem 0.5rem; font-size: 0.8rem;">
                                <%= vnd.city %>, <%= vnd.country %>
                            </td>
                            <td style="padding: 0.75rem 0.5rem; text-align: right;">
                                <div style="display: flex; gap: 0.5rem; justify-content: flex-end;">
                                    <form action="/admin/vendors/approve/<%= vnd.id %>" method="POST" style="display: inline;">
                                        <button type="submit" class="btn btn-primary" style="padding: 0.35rem 0.75rem; font-size: 0.75rem; border-radius: 6px; background: rgba(16,185,129,0.2); border-color: var(--color-success); color: var(--color-success);">
                                            Approve
                                        </button>
                                    </form>
                                    <form action="/admin/vendors/reject/<%= vnd.id %>" method="POST" style="display: inline;">
                                        <button type="submit" class="btn btn-secondary" style="padding: 0.35rem 0.75rem; font-size: 0.75rem; border-radius: 6px; border-color: rgba(239,68,68,0.3); color: var(--color-danger);" onclick="return confirm('Reject this vendor onboarding request?')">
                                            Reject
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    <% } %>
</div>

<!-- 2. APPROVED VENDORS CARD -->
<div class="glass-card" style="padding: 2rem; margin-bottom: 2rem;">
    <h3 style="font-size: 1.25rem; margin-bottom: 1.25rem; display: flex; align-items: center; gap: 0.5rem; color: var(--color-success);">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
        Approved Supplier Directory (<%= approved.length %>)
    </h3>
    
    <% if (approved.length === 0) { %>
        <p style="color: var(--color-text-muted); text-align: center; padding: 2rem 0;">No approved suppliers registered in database yet.</p>
    <% } else { %>
        <div style="overflow-x: auto;">
            <table style="width: 100%; border-collapse: collapse; text-align: left; font-size: 0.9rem;">
                <thead>
                    <tr style="border-bottom: 1px solid rgba(255,255,255,0.06); color: var(--color-text-muted);">
                        <th style="padding: 0.75rem 0.5rem;">Company Info</th>
                        <th style="padding: 0.75rem 0.5rem;">GST / Tax Number</th>
                        <th style="padding: 0.75rem 0.5rem;">Category</th>
                        <th style="padding: 0.75rem 0.5rem;">Contact Person</th>
                        <th style="padding: 0.75rem 0.5rem;">Full Address</th>
                        <th style="padding: 0.75rem 0.5rem; text-align: right;">Status Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% approved.forEach(vnd => { %>
                        <tr style="border-bottom: 1px solid rgba(255,255,255,0.03);">
                            <td style="padding: 0.75rem 0.5rem;">
                                <strong style="color: #ffffff; display: block;"><%= vnd.company_name %></strong>
                                <span style="font-size: 0.75rem; color: var(--color-text-muted);"><%= vnd.email %></span>
                            </td>
                            <td style="padding: 0.75rem 0.5rem; font-family: monospace;"><%= vnd.gst_number %></td>
                            <td style="padding: 0.75rem 0.5rem;"><%= vnd.category %></td>
                            <td style="padding: 0.75rem 0.5rem;">
                                <span style="display: block; font-weight: 500;"><%= vnd.contact_name %></span>
                                <span style="font-size: 0.75rem; color: var(--color-text-muted);"><%= vnd.phone %></span>
                            </td>
                            <td style="padding: 0.75rem 0.5rem; font-size: 0.8rem; max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                <%= vnd.address %>, <%= vnd.city %>, <%= vnd.state %>, <%= vnd.country %>
                            </td>
                            <td style="padding: 0.75rem 0.5rem; text-align: right;">
                                <form action="/admin/vendors/reject/<%= vnd.id %>" method="POST" style="display: inline;">
                                    <button type="submit" class="btn btn-secondary" style="padding: 0.35rem 0.75rem; font-size: 0.75rem; border-radius: 6px; border-color: rgba(239,68,68,0.2); color: var(--color-danger);" onclick="return confirm('Suspending vendor will prevent them from bidding on RFQs. Continue?')">
                                        Suspend / Reject
                                    </button>
                                </form>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    <% } %>
</div>

<!-- 3. REJECTED VENDORS CARD -->
<div class="glass-card" style="padding: 2rem;">
    <h3 style="font-size: 1.25rem; margin-bottom: 1.25rem; display: flex; align-items: center; gap: 0.5rem; color: var(--color-danger);">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="15" y1="9" x2="9" y2="15"></line><line x1="9" y1="9" x2="15" y2="15"></line></svg>
        Rejected / Suspended Suppliers (<%= rejected.length %>)
    </h3>
    
    <% if (rejected.length === 0) { %>
        <p style="color: var(--color-text-muted); text-align: center; padding: 2rem 0;">No rejected supplier profiles on file.</p>
    <% } else { %>
        <div style="overflow-x: auto;">
            <table style="width: 100%; border-collapse: collapse; text-align: left; font-size: 0.9rem;">
                <thead>
                    <tr style="border-bottom: 1px solid rgba(255,255,255,0.06); color: var(--color-text-muted);">
                        <th style="padding: 0.75rem 0.5rem;">Company Info</th>
                        <th style="padding: 0.75rem 0.5rem;">GST / Tax Number</th>
                        <th style="padding: 0.75rem 0.5rem;">Category</th>
                        <th style="padding: 0.75rem 0.5rem;">Contact Details</th>
                        <th style="padding: 0.75rem 0.5rem; text-align: right;">Status Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% rejected.forEach(vnd => { %>
                        <tr style="border-bottom: 1px solid rgba(255,255,255,0.03);">
                            <td style="padding: 0.75rem 0.5rem;">
                                <strong style="color: #ffffff; display: block;"><%= vnd.company_name %></strong>
                                <span style="font-size: 0.75rem; color: var(--color-text-muted);"><%= vnd.email %></span>
                            </td>
                            <td style="padding: 0.75rem 0.5rem; font-family: monospace;"><%= vnd.gst_number %></td>
                            <td style="padding: 0.75rem 0.5rem;"><%= vnd.category %></td>
                            <td style="padding: 0.75rem 0.5rem;">
                                <span style="display: block; font-weight: 500;"><%= vnd.contact_name %></span>
                                <span style="font-size: 0.75rem; color: var(--color-text-muted);"><%= vnd.phone %></span>
                            </td>
                            <td style="padding: 0.75rem 0.5rem; text-align: right;">
                                <form action="/admin/vendors/approve/<%= vnd.id %>" method="POST" style="display: inline;">
                                    <button type="submit" class="btn btn-primary" style="padding: 0.35rem 0.75rem; font-size: 0.75rem; border-radius: 6px; background: rgba(16,185,129,0.1); border-color: var(--color-success); color: var(--color-success);" onclick="return confirm('Re-approve this supplier and restore active bidding status?')">
                                        Re-Approve
                                    </button>
                                </form>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    <% } %>
</div>

<%- include('../partials/footer') %>
