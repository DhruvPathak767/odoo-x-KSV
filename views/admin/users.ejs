<%- include('../partials/header') %>

    <div style="margin-bottom: 2rem;">
        <h1 style="font-size: 2.2rem; margin-bottom: 0.5rem;">Manage Users</h1>
        <p style="color: var(--color-text-secondary);">Modify system authorization levels, change roles, or toggle
            account access privileges.</p>
    </div>

    <!-- Alert Banner Feedback -->
    <% if (success) { %>
        <div class="alert-banner alert-banner-success" style="margin-bottom: 1.5rem;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                <polyline points="22 4 12 14.01 9 11.01"></polyline>
            </svg>
            <span>
                <% if (success==='status_updated' ) { %>
                    User status updated successfully!
                    <% } else if (success==='role_updated' ) { %>
                        User role updated successfully!
                        <% } else { %>
                            <%= success %>
                                <% } %>
            </span>
        </div>
        <% } %>

            <% if (error) { %>
                <div class="alert-banner alert-banner-error" style="margin-bottom: 1.5rem;">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"></circle>
                        <line x1="12" y1="8" x2="12" y2="12"></line>
                        <line x1="12" y1="16" x2="12.01" y2="16"></line>
                    </svg>
                    <span>
                        <% if (error==='cannot_deactivate_self' ) { %>
                            Forbidden: You cannot deactivate your own administrative account!
                            <% } else if (error==='cannot_change_own_role' ) { %>
                                Forbidden: You cannot change your own role!
                                <% } else if (error==='user_not_found' ) { %>
                                    User profile was not found.
                                    <% } else { %>
                                        <%= error %>
                                            <% } %>
                    </span>
                </div>
                <% } %>

                    <div class="glass-card" style="padding: 2rem;">
                        <div style="overflow-x: auto;">
                            <table
                                style="width: 100%; border-collapse: collapse; text-align: left; font-size: 0.95rem;">
                                <thead>
                                    <tr
                                        style="border-bottom: 1px solid rgba(255,255,255,0.08); color: var(--color-text-muted);">
                                        <th style="padding: 1rem 0.5rem;">Name</th>
                                        <th style="padding: 1rem 0.5rem;">Email Address</th>
                                        <th style="padding: 1rem 0.5rem;">Registered On</th>
                                        <th style="padding: 1rem 0.5rem;">Role Assignment</th>
                                        <th style="padding: 1rem 0.5rem; text-align: center;">Status</th>
                                        <th style="padding: 1rem 0.5rem; text-align: right;">Access Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% users.forEach(usr=> { %>
                                        <tr
                                            style="border-bottom: 1px solid rgba(255,255,255,0.03); transition: background-color 0.2s;">
                                            <td style="padding: 1rem 0.5rem; font-weight: 600; color: #ffffff;">
                                                <%= usr.name %>
                                            </td>
                                            <td style="padding: 1rem 0.5rem; font-family: monospace;">
                                                <%= usr.email %>
                                            </td>
                                            <td style="padding: 1rem 0.5rem; font-size: 0.85rem;">
                                                <%= new Date(usr.created_at).toLocaleDateString() %>
                                            </td>

                                            <!-- Role change form -->
                                            <td style="padding: 1rem 0.5rem;">
                                                <% if (usr.id===user.id) { %>
                                                    <span class="badge"
                                                        style="border-color: var(--color-primary); color: var(--color-primary);">
                                                        SYSTEM ADMIN (YOU)
                                                    </span>
                                                    <% } else { %>
                                                        <form action="/admin/users/change-role/<%= usr.id %>"
                                                            method="POST"
                                                            style="display: flex; gap: 0.5rem; align-items: center;">
                                                            <select name="role" class="form-control"
                                                                style="padding: 0.35rem 0.5rem; font-size: 0.8rem; border-radius: 6px; background: rgba(0,0,0,0.4); width: 160px; height: auto;"
                                                                required>
                                                                <option value="admin" <%=usr.role==='admin' ? 'selected'
                                                                    : '' %>>Admin</option>
                                                                <option value="procurement_officer"
                                                                    <%=usr.role==='procurement_officer' ? 'selected'
                                                                    : '' %>>Procurement Officer</option>
                                                                <option value="manager" <%=usr.role==='manager'
                                                                    ? 'selected' : '' %>>Approving Manager</option>
                                                                <option value="vendor" <%=usr.role==='vendor'
                                                                    ? 'selected' : '' %>>External Vendor</option>
                                                            </select>
                                                            <button type="submit" class="btn btn-secondary"
                                                                style="padding: 0.35rem 0.6rem; font-size: 0.75rem; border-radius: 6px;">
                                                                Update
                                                            </button>
                                                        </form>
                                                        <% } %>
                                            </td>

                                            <!-- Status badge -->
                                            <td style="padding: 1rem 0.5rem; text-align: center;">
                                                <% if (usr.is_active) { %>
                                                    <span
                                                        style="background: rgba(16,185,129,0.1); color: var(--color-success); padding: 0.2rem 0.5rem; border-radius: 100px; font-size: 0.75rem; font-weight: bold;">
                                                        Active
                                                    </span>
                                                    <% } else { %>
                                                        <span
                                                            style="background: rgba(239,68,68,0.1); color: var(--color-danger); padding: 0.2rem 0.5rem; border-radius: 100px; font-size: 0.75rem; font-weight: bold;">
                                                            Suspended
                                                        </span>
                                                        <% } %>
                                            </td>

                                            <!-- Toggle Access button -->
                                            <td style="padding: 1rem 0.5rem; text-align: right;">
                                                <% if (usr.id !==user.id) { %>
                                                    <form action="/admin/users/toggle-status/<%= usr.id %>"
                                                        method="POST" style="display: inline;">
                                                        <% if (usr.is_active) { %>
                                                            <button type="submit" class="btn btn-secondary"
                                                                style="padding: 0.4rem 0.8rem; font-size: 0.75rem; border-radius: 8px; border-color: rgba(239,68,68,0.3); color: var(--color-danger);"
                                                                onclick="return confirm('Are you sure you want to deactivate and suspend access for <%= usr.name %>?')">
                                                                Suspend Access
                                                            </button>
                                                            <% } else { %>
                                                                <button type="submit" class="btn btn-primary"
                                                                    style="padding: 0.4rem 0.8rem; font-size: 0.75rem; border-radius: 8px; background: rgba(16,185,129,0.2); border-color: var(--color-success); color: var(--color-success);"
                                                                    onclick="return confirm('Activate system access for <%= usr.name %>?')">
                                                                    Activate Access
                                                                </button>
                                                                <% } %>
                                                    </form>
                                                    <% } else { %>
                                                        <span
                                                            style="font-size: 0.8rem; color: var(--color-text-muted); font-style: italic;">No
                                                            Action</span>
                                                        <% } %>
                                            </td>
                                        </tr>
                                        <% }) %>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <%- include('../partials/footer') %>