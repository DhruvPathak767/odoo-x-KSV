<%- include('../partials/header') %>

<div class="dashboard-hero" style="margin-bottom: 2rem;">
    <div class="glass-card dashboard-welcome-card" style="padding: 2.5rem 2rem;">
        <div class="grid-overlay"></div>
        <div class="badge-wrapper">
            <span class="badge" style="border-color: rgba(236,72,153,0.25); color: var(--color-primary);">
                <span class="badge-pulse" style="background-color: var(--color-primary);"></span>
                ERP System Owner Console
            </span>
        </div>
        <h1 style="font-size: 2.5rem; margin-bottom: 0.5rem;">
            Administrator Cockpit
        </h1>
        <p style="color: var(--color-text-secondary); max-width: 600px;">
            Manage user roles and permissions, review external vendor onboarding applications, and inspect procurement metrics.
        </p>
        
        <div style="display: flex; gap: 1rem; margin-top: 1.5rem; flex-wrap: wrap;">
            <a href="/admin/users" class="btn btn-primary btn-glow" style="font-size: 0.85rem; padding: 0.6rem 1.25rem;">
                Manage System Users
            </a>
            <a href="/admin/vendors" class="btn btn-secondary" style="font-size: 0.85rem; padding: 0.6rem 1.25rem; border-radius: 8px;">
                Review Vendor Applications (<%= metrics.pendingVendors %>)
            </a>
        </div>
    </div>
</div>

<!-- Metrics Grid -->
<div class="metrics-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.5rem; margin-bottom: 2rem;">
    <!-- Total Users -->
    <div class="glass-card" style="padding: 1.75rem 1.5rem; min-height: 140px; display: flex; flex-direction: column; justify-content: space-between;">
        <div style="display: flex; justify-content: space-between; align-items: center;">
            <span style="font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-muted); font-family: 'Outfit'; font-weight: 600;">System Users</span>
            <span class="metric-icon" style="background: rgba(99, 102, 241, 0.15); color: #818cf8; padding: 0.35rem 0.5rem; border-radius: 8px;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
            </span>
        </div>
        <div>
            <div style="font-size: 2.5rem; font-weight: 800; color: #ffffff;"><%= metrics.users %></div>
            <span style="font-size: 0.75rem; color: var(--color-text-secondary);">Registered user profiles</span>
        </div>
    </div>

    <!-- Pending Vendors -->
    <div class="glass-card" style="padding: 1.75rem 1.5rem; min-height: 140px; display: flex; flex-direction: column; justify-content: space-between;">
        <div style="display: flex; justify-content: space-between; align-items: center;">
            <span style="font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-muted); font-family: 'Outfit'; font-weight: 600;">Pending Applications</span>
            <span class="metric-icon" style="background: rgba(245, 158, 11, 0.15); color: #fbbf24; padding: 0.35rem 0.5rem; border-radius: 8px;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
            </span>
        </div>
        <div>
            <div style="font-size: 2.5rem; font-weight: 800; color: #ffffff;"><%= metrics.pendingVendors %></div>
            <span style="font-size: 0.75rem; color: var(--color-warning);">Vendors awaiting review</span>
        </div>
    </div>

    <!-- Approved Vendors -->
    <div class="glass-card" style="padding: 1.75rem 1.5rem; min-height: 140px; display: flex; flex-direction: column; justify-content: space-between;">
        <div style="display: flex; justify-content: space-between; align-items: center;">
            <span style="font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-muted); font-family: 'Outfit'; font-weight: 600;">Approved Vendors</span>
            <span class="metric-icon" style="background: rgba(16, 185, 129, 0.15); color: #34d399; padding: 0.35rem 0.5rem; border-radius: 8px;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
            </span>
        </div>
        <div>
            <div style="font-size: 2.5rem; font-weight: 800; color: #ffffff;"><%= metrics.approvedVendors %></div>
            <span style="font-size: 0.75rem; color: var(--color-success);">Verified supplier partners</span>
        </div>
    </div>

    <!-- Active RFQs -->
    <div class="glass-card" style="padding: 1.75rem 1.5rem; min-height: 140px; display: flex; flex-direction: column; justify-content: space-between;">
        <div style="display: flex; justify-content: space-between; align-items: center;">
            <span style="font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-muted); font-family: 'Outfit'; font-weight: 600;">Active RFQs</span>
            <span class="metric-icon" style="background: rgba(236, 72, 153, 0.15); color: var(--color-primary); padding: 0.35rem 0.5rem; border-radius: 8px;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline></svg>
            </span>
        </div>
        <div>
            <div style="font-size: 2.5rem; font-weight: 800; color: #ffffff;"><%= metrics.activeRFQs %></div>
            <span style="font-size: 0.75rem; color: var(--color-primary);">Open bidding cycles</span>
        </div>
    </div>
</div>

<div style="display: grid; grid-template-columns: 2fr 1fr; gap: 2rem;">
    <!-- Recent Users Table -->
    <div class="glass-card" style="padding: 2rem;">
        <h3 style="font-size: 1.25rem; margin-bottom: 1.25rem; display: flex; align-items: center; gap: 0.5rem;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-primary);"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
            Recent User Accounts
        </h3>
        
        <div style="overflow-x: auto;">
            <table style="width: 100%; border-collapse: collapse; text-align: left; font-size: 0.9rem;">
                <thead>
                    <tr style="border-bottom: 1px solid rgba(255,255,255,0.06); color: var(--color-text-muted);">
                        <th style="padding: 0.75rem 0.5rem;">Name</th>
                        <th style="padding: 0.75rem 0.5rem;">Email</th>
                        <th style="padding: 0.75rem 0.5rem;">System Role</th>
                        <th style="padding: 0.75rem 0.5rem; text-align: center;">Status</th>
                    </tr>
                </thead>
                <tbody>
                    <% recentUsers.forEach(user => { %>
                        <tr style="border-bottom: 1px solid rgba(255,255,255,0.03);">
                            <td style="padding: 0.75rem 0.5rem; font-weight: 500; color: #ffffff;"><%= user.name %></td>
                            <td style="padding: 0.75rem 0.5rem;"><%= user.email %></td>
                            <td style="padding: 0.75rem 0.5rem;">
                                <span class="badge" style="border-color: rgba(255,255,255,0.1); font-size: 0.75rem;">
                                    <%= user.role.toUpperCase().replace('_', ' ') %>
                                </span>
                            </td>
                            <td style="padding: 0.75rem 0.5rem; text-align: center;">
                                <% if (user.is_active) { %>
                                    <span style="color: var(--color-success); font-size: 0.8rem;">● Active</span>
                                <% } else { %>
                                    <span style="color: var(--color-danger); font-size: 0.8rem;">● Suspended</span>
                                <% } %>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
        <div style="margin-top: 1.5rem; text-align: right;">
            <a href="/admin/users" style="color: var(--color-primary); font-size: 0.85rem;" class="hover-underline">View All Users &rarr;</a>
        </div>
    </div>

    <!-- Quick Tools -->
    <div class="glass-card" style="padding: 2rem;">
        <h3 style="font-size: 1.25rem; margin-bottom: 1.25rem;">Quick Operations</h3>
        <div style="display: flex; flex-direction: column; gap: 1rem;">
            <a href="/admin/users" style="display: flex; align-items: center; justify-content: space-between; background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.04); padding: 1rem; border-radius: 10px; transition: all 0.3s;" class="hover-glow-card">
                <div>
                    <strong style="color: #ffffff; display: block; font-size: 0.9rem;">Suspend Accounts</strong>
                    <span style="font-size: 0.75rem; color: var(--color-text-muted);">Deactivate system access</span>
                </div>
                <span style="color: var(--color-primary);">&rarr;</span>
            </a>
            
            <a href="/admin/vendors" style="display: flex; align-items: center; justify-content: space-between; background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.04); padding: 1rem; border-radius: 10px; transition: all 0.3s;" class="hover-glow-card">
                <div>
                    <strong style="color: #ffffff; display: block; font-size: 0.9rem;">Approve Suppliers</strong>
                    <span style="font-size: 0.75rem; color: var(--color-text-muted);">Authorize pending applications</span>
                </div>
                <span style="color: var(--color-primary);">&rarr;</span>
            </a>

            <a href="/admin/analytics" style="display: flex; align-items: center; justify-content: space-between; background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.04); padding: 1rem; border-radius: 10px; transition: all 0.3s;" class="hover-glow-card">
                <div>
                    <strong style="color: #ffffff; display: block; font-size: 0.9rem;">Analytics Audits</strong>
                    <span style="font-size: 0.75rem; color: var(--color-text-muted);">View budget spend summaries</span>
                </div>
                <span style="color: var(--color-primary);">&rarr;</span>
            </a>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
