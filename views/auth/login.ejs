<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <meta name="description" content="Login to VendorBridge ERP platform.">
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <!-- Main Stylesheet -->
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <!-- Premium Noise & Spotlight overlays -->
    <div class="noise-overlay"></div>
    <div class="global-spotlight"></div>

    <!-- Background Particle Canvas -->
    <canvas id="particles-canvas"></canvas>

    <!-- Background Glow Orbs -->
    <div class="glow-orb glow-orb-1"></div>
    <div class="glow-orb glow-orb-2"></div>
    <div class="glow-orb glow-orb-3"></div>

    <!-- HEADER / NAVIGATION -->
    <header class="navbar scrolled" id="navbar">
        <div class="nav-container">
            <a href="/" class="logo-group" id="nav-logo">
                <svg class="logo-icon" width="36" height="36" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <defs>
                        <linearGradient id="logo-grad" x1="0%" y1="0%" x2="100%" y2="100%">
                            <stop offset="0%" stop-color="#ec4899" />
                            <stop offset="100%" stop-color="#6366f1" />
                        </linearGradient>
                    </defs>
                    <path d="M20 70 L40 30 L60 30 L80 70" stroke="url(#logo-grad)" stroke-width="10" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M30 55 L70 55" stroke="#ec4899" stroke-width="8" stroke-linecap="round"/>
                    <circle cx="50" cy="30" r="8" fill="#ec4899" class="logo-dot" />
                </svg>
                <span class="logo-text">Vendor<span>Bridge</span></span>
            </a>

            <div class="nav-actions">
                <a href="/" class="btn btn-secondary btn-nav">Back to Home</a>
            </div>
        </div>
    </header>

    <!-- MAIN LOGIN SECTION -->
    <main class="auth-section">
        <div class="auth-container">
            <div class="glass-card auth-card">
                <div class="grid-overlay"></div>
                <div class="auth-header">
                    <h2>Welcome Back</h2>
                    <p>Enter your details to access the VendorBridge ERP</p>
                </div>

                <!-- Alert Banners for Server side feedback -->
                <div id="alert-container">
                    <% if (error) { %>
                        <div class="alert-banner alert-banner-error">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
                            <span><%= error === 'account_deactivated' ? 'This account has been deactivated.' : error %></span>
                        </div>
                    <% } %>
                    <% if (success) { %>
                        <div class="alert-banner alert-banner-success">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                            <span>
                                <% if (success === 'account_created') { %>
                                    Account created successfully! Please login below.
                                <% } else if (success === 'password_reset') { %>
                                    Your password has been reset. You can now login.
                                <% } else if (success === 'logged_out') { %>
                                    Logged out successfully.
                                <% } else { %>
                                    <%= success %>
                                <% } %>
                            </span>
                        </div>
                    <% } %>
                </div>

                <form class="auth-form" id="login-form" method="POST" action="/auth/login">
                    <div class="form-group">
                        <label for="email" class="form-label">Business Email</label>
                        <div class="form-control-wrapper">
                            <input type="email" id="email" name="email" class="form-control" placeholder="name@company.com" required autocomplete="email">
                        </div>
                    </div>

                    <div class="form-group">
                        <div class="form-footer-actions">
                            <label for="password" class="form-label">Password</label>
                            <a href="/auth/forgot-password" class="forgot-link">Forgot password?</a>
                        </div>
                        <div class="form-control-wrapper">
                            <input type="password" id="password" name="password" class="form-control" placeholder="••••••••" required autocomplete="current-password">
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary btn-glow btn-auth-submit" id="btn-submit">
                        <span>Sign In</span>
                    </button>
                </form>

                <p class="auth-nav-tip">
                    New to VendorBridge? <a href="/auth/register">Create an account</a>
                </p>
            </div>
        </div>
    </main>

    <!-- Main JavaScript Files -->
    <script src="/script.js"></script>
    <script src="/js/auth.js"></script>
</body>
</html>
