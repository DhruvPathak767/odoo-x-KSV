<%- include('../partials/header') %>

<div style="margin-bottom: 2rem; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
    <div>
        <h1 style="font-size: 2.2rem; margin-bottom: 0.5rem;">Purchase Orders</h1>
        <p style="color: var(--color-text-secondary);">Track agreements, deliveries, and billing status for issued POs.</p>
    </div>
    <% if (role !== 'vendor') { %>
    <div style="display: flex; gap: 0.5rem; align-items: center;">
        <span style="font-size: 0.8rem; color: var(--color-text-muted); margin-right: 0.25rem;">Export:</span>
        <a href="/reports/export?entity=pos&type=pdf" class="btn btn-secondary" style="padding: 0.55rem 0.8rem; font-size: 0.8rem; border-radius: 8px;">PDF</a>
        <a href="/reports/export?entity=pos&type=excel" class="btn btn-secondary" style="padding: 0.55rem 0.8rem; font-size: 0.8rem; border-radius: 8px;">Excel</a>
        <a href="/reports/export?entity=pos&type=csv" class="btn btn-secondary" style="padding: 0.55rem 0.8rem; font-size: 0.8rem; border-radius: 8px;">CSV</a>
    </div>
    <% } %>
</div>

<div class="glass-card" style="padding: 2rem;">
    <% if (pos.length === 0) { %>
        <div style="text-align: center; padding: 3rem 0; color: var(--color-text-muted);">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom: 1rem; color: var(--color-text-muted);"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline></svg>
            <p>No Purchase Orders logged in the database.</p>
        </div>
    <% } else { %>
        <div style="overflow-x: auto;">
            <table style="width: 100%; border-collapse: collapse; text-align: left; font-size: 0.95rem;">
                <thead>
                    <tr style="border-bottom: 1px solid rgba(255,255,255,0.08); color: var(--color-text-muted);">
                        <th style="padding: 1rem 0.5rem;">PO Number</th>
                        <th style="padding: 1rem 0.5rem;">RFQ Reference</th>
                        <th style="padding: 1rem 0.5rem;">Supplier Partner</th>
                        <th style="padding: 1rem 0.5rem;">Issued Date</th>
                        <th style="padding: 1rem 0.5rem; text-align: center;">Status</th>
                        <th style="padding: 1rem 0.5rem; text-align: right;">Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% pos.forEach(po => { %>
                        <tr style="border-bottom: 1px solid rgba(255,255,255,0.03); transition: background-color 0.2s;">
                            <td style="padding: 1rem 0.5rem; font-family: monospace; font-weight: 700; color: var(--color-primary);">
                                <%= po.po_number %>
                            </td>
                            <td style="padding: 1rem 0.5rem;">
                                <strong style="color: #ffffff;"><%= po.rfq_title %></strong>
                            </td>
                            <td style="padding: 1rem 0.5rem;"><%= po.company_name %></td>
                            <td style="padding: 1rem 0.5rem; font-size: 0.85rem;"><%= new Date(po.created_at).toLocaleDateString() %></td>
                            <td style="padding: 1rem 0.5rem; text-align: center;">
                                <% 
                                let statusColor = '#fbbf24'; 
                                let statusBg = 'rgba(245,158,11,0.15)';
                                if (po.status === 'Completed') { statusColor = 'var(--color-success)'; statusBg = 'rgba(16,185,129,0.15)'; }
                                if (po.status === 'Cancelled') { statusColor = 'var(--color-danger)'; statusBg = 'rgba(239,68,68,0.15)'; }
                                if (po.status === 'Sent') { statusColor = 'var(--color-secondary)'; statusBg = 'rgba(99,102,241,0.15)'; }
                                %>
                                <span style="background: <%= statusBg %>; color: <%= statusColor %>; padding: 0.25rem 0.6rem; border-radius: 100px; font-size: 0.75rem; font-weight: bold; border: 1px solid rgba(255,255,255,0.03);">
                                    <%= po.status %>
                                </span>
                            </td>
                            <td style="padding: 1rem 0.5rem; text-align: right;">
                                <% 
                                const viewPath = role === 'vendor' 
                                    ? `/vendor/po/${po.id}` 
                                    : `/procurement/po/${po.id}`; 
                                %>
                                <a href="<%= viewPath %>" class="btn btn-secondary" style="padding: 0.4rem 0.85rem; font-size: 0.75rem; border-radius: 8px;">
                                    View details &rarr;
                                </a>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    <% } %>
</div>

<%- include('../partials/footer') %>
