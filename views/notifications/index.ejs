<%- include('../partials/header') %>

<div style="margin-bottom: 2rem; display: flex; justify-content: space-between; align-items: center;">
    <div>
        <h1 style="font-size: 2.2rem; margin-bottom: 0.5rem;">Notification Center</h1>
        <p style="color: var(--color-text-secondary);">Stay up to date with RFQ activities, submissions, cost approvals, and purchase orders.</p>
    </div>
    <% if (notifications.some(n => !n.is_read)) { %>
        <form action="/notifications/read-all" method="POST" style="margin: 0;">
            <button type="submit" class="btn btn-primary" style="padding: 0.6rem 1.2rem; font-size: 0.9rem; border-radius: 8px;">
                Mark All Read
            </button>
        </form>
    <% } %>
</div>

<div class="glass-card" style="padding: 2rem;">
    <div id="notifications-container" style="display: flex; flex-direction: column; gap: 1rem;">
        <% if (notifications && notifications.length > 0) { %>
            <% notifications.forEach(notif => { %>
                <div class="notification-row" data-id="<%= notif.id %>" style="display: flex; justify-content: space-between; align-items: center; padding: 1.25rem; border-radius: 12px; background: <%= notif.is_read ? 'rgba(255,255,255,0.02)' : 'rgba(99,102,241,0.08)' %>; border: 1px solid <%= notif.is_read ? 'rgba(255,255,255,0.05)' : 'rgba(99,102,241,0.3)' %>; border-left: 4px solid <%= notif.is_read ? 'rgba(255,255,255,0.1)' : 'var(--color-primary)' %>; transition: transform 0.2s, background-color 0.2s;">
                    <div style="flex: 1; text-align: left; padding-right: 1.5rem;">
                        <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.35rem;">
                            <span style="font-weight: 700; font-size: 1.05rem; color: #ffffff;"><%= notif.title %></span>
                            <span class="badge" style="font-size: 0.7rem; padding: 0.15rem 0.4rem; border-radius: 4px; text-transform: uppercase; border-color: rgba(255,255,255,0.15); color: var(--color-text-secondary);">
                                <%= notif.type.replace('_', ' ') %>
                            </span>
                            <% if (!notif.is_read) { %>
                                <span class="badge-unread-dot" style="width: 8px; height: 8px; border-radius: 50%; background: var(--color-primary); display: inline-block; box-shadow: 0 0 6px var(--color-primary);"></span>
                            <% } %>
                        </div>
                        <div style="font-size: 0.9rem; color: var(--color-text-secondary); line-height: 1.4; margin-bottom: 0.5rem;"><%= notif.message %></div>
                        <div style="font-size: 0.75rem; color: var(--color-text-muted);"><%= new Date(notif.created_at).toLocaleString() %></div>
                    </div>
                    <div>
                        <% if (!notif.is_read) { %>
                            <button class="btn btn-secondary" style="padding: 0.4rem 0.8rem; font-size: 0.8rem; border-radius: 6px;" onclick="markAsReadInline(<%= notif.id %>, this)">
                                Mark Read
                            </button>
                        <% } %>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div style="padding: 3rem; text-align: center; color: var(--color-text-muted);">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="margin-bottom: 1rem; opacity: 0.4;">
                    <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path>
                    <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
                </svg>
                <div style="font-size: 1.1rem; font-weight: 500; margin-bottom: 0.25rem;">No Notifications Found</div>
                <p style="font-size: 0.9rem;">You are all caught up! When system updates occur, they will appear here.</p>
            </div>
        <% } %>
    </div>
</div>

<style>
    .notification-row:hover {
        transform: translateX(3px);
        background: rgba(255, 255, 255, 0.04) !important;
    }
</style>

<script>
    async function markAsReadInline(id, btn) {
        try {
            const response = await fetch(`/notifications/read/${id}`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                }
            });
            const data = await response.json();
            if (data.success) {
                const row = btn.closest('.notification-row');
                if (row) {
                    row.style.background = 'rgba(255,255,255,0.02)';
                    row.style.borderColor = 'rgba(255,255,255,0.05)';
                    row.style.borderLeftColor = 'rgba(255,255,255,0.1)';
                    const dot = row.querySelector('.badge-unread-dot');
                    if (dot) dot.remove();
                }
                btn.remove();
                
                // Update navigation bell badge
                const badge = document.getElementById('notification-badge');
                if (badge) {
                    let count = parseInt(badge.innerText, 10);
                    if (count > 1) {
                        badge.innerText = count - 1;
                    } else {
                        badge.remove();
                    }
                }
            }
        } catch (err) {
            console.error('Error marking notification read:', err);
        }
    }
</script>

<%- include('../partials/footer') %>
