<%- include('../partials/header') %>

    <div style="margin-bottom: 2rem;">
        <a href="/procurement/rfqs"
            style="color: var(--color-primary); font-size: 0.9rem; display: inline-flex; align-items: center; gap: 0.25rem; margin-bottom: 0.75rem;">
            &larr; Back to RFQ List
        </a>
        <h1 style="font-size: 2.2rem; margin-bottom: 0.5rem;">Quotation Comparison Matrix</h1>
        <p style="color: var(--color-text-secondary);">Evaluate bids submitted for: <strong>
                <%= rfq.title %>
            </strong> (Allocated Budget: <strong style="color: #ffffff;">$<%= parseFloat(rfq.budget).toLocaleString() %>
                    </strong>)</p>
        <% if (rfq.attachment) { %>
            <div style="margin-top: 0.5rem; font-size: 0.9rem;">
                <span style="color: var(--color-text-secondary);">Guidelines Attachment:</span>
                <a href="/uploads/<%= rfq.attachment %>" target="_blank"
                    style="color: var(--color-primary); font-weight: 600; text-decoration: none; display: inline-flex; align-items: center; gap: 0.25rem; margin-left: 0.25rem;">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                        stroke-linecap="round" stroke-linejoin="round">
                        <path
                            d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48">
                        </path>
                    </svg>
                    Download Issued SOW
                </a>
            </div>
            <% } %>
    </div>

    <!-- Alert notification -->
    <div id="alert-container">
        <% if (locals.success) { %>
            <div class="alert-banner alert-banner-success" style="margin-bottom: 1.5rem;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                    <polyline points="22 4 12 14.01 9 11.01"></polyline>
                </svg>
                <span>
                    <%= success %>
                </span>
            </div>
            <% } %>
    </div>

    <!-- Matrix display -->
    <div class="glass-card" style="padding: 2rem; margin-bottom: 2.5rem;">
        <h3
            style="font-size: 1.25rem; border-bottom: 1px solid rgba(255,255,255,0.08); padding-bottom: 0.5rem; margin-bottom: 1.5rem; color: var(--color-primary); display: flex; align-items: center; gap: 0.5rem;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                stroke-linecap="round" stroke-linejoin="round">
                <line x1="18" y1="20" x2="18" y2="10"></line>
                <line x1="12" y1="20" x2="12" y2="4"></line>
                <line x1="6" y1="20" x2="6" y2="14"></line>
            </svg>
            Side-by-Side Quotation Comparison (Total bids: <%= quotations.length %>)
        </h3>

        <% if (quotations.length===0) { %>
            <div style="text-align: center; padding: 3rem 0; color: var(--color-text-muted);">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"
                    stroke-linecap="round" stroke-linejoin="round"
                    style="margin-bottom: 1rem; color: var(--color-text-muted);">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                </svg>
                <p>No vendor quotations have been submitted for this RFQ yet.</p>
            </div>
            <% } else { %>
                <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem;">
                    <% quotations.forEach(q=> { %>
                        <% const isLowestPrice=(q.id===lowestPriceQuoteId); const
                            isFastestDelivery=(q.id===fastestDeliveryQuoteId); %>
                            <div class="glass-card"
                                style="padding: 1.5rem; border-color: <%= isLowestPrice ? 'var(--color-success)' : (isFastestDelivery ? 'var(--color-accent)' : 'rgba(255,255,255,0.06)') %>; background: <%= isLowestPrice ? 'rgba(16,185,129,0.03)' : (isFastestDelivery ? 'rgba(168,85,247,0.03)' : 'var(--glass-bg)') %>; position: relative;">

                                <!-- Highlights badges -->
                                <div
                                    style="position: absolute; top: 1rem; right: 1rem; display: flex; flex-direction: column; gap: 0.25rem;">
                                    <% if (isLowestPrice) { %>
                                        <span
                                            style="font-size: 0.65rem; background: var(--color-success); color: #ffffff; padding: 0.15rem 0.45rem; border-radius: 4px; font-weight: bold; text-transform: uppercase;">L1
                                            Low Bid</span>
                                        <% } %>
                                            <% if (isFastestDelivery) { %>
                                                <span
                                                    style="font-size: 0.65rem; background: var(--color-accent); color: #ffffff; padding: 0.15rem 0.45rem; border-radius: 4px; font-weight: bold; text-transform: uppercase;">Fastest
                                                    Timeline</span>
                                                <% } %>
                                </div>

                                <strong
                                    style="font-size: 1.15rem; color: #ffffff; display: block; margin-bottom: 1rem; max-width: 70%;">
                                    <%= q.company_name %>
                                </strong>

                                <!-- Proposal Grid -->
                                <div style="display: flex; flex-direction: column; gap: 0.75rem; font-size: 0.85rem;">
                                    <div
                                        style="display: flex; justify-content: space-between; border-bottom: 1px solid rgba(255,255,255,0.03); padding-bottom: 0.25rem;">
                                        <span style="color: var(--color-text-muted);">Proposed Price</span>
                                        <strong
                                            style="color: <%= isLowestPrice ? 'var(--color-success)' : '#ffffff' %>; font-family: monospace; font-size: 0.95rem;">$
                                            <%= parseFloat(q.price).toLocaleString() %></strong>
                                    </div>

                                    <div
                                        style="display: flex; justify-content: space-between; border-bottom: 1px solid rgba(255,255,255,0.03); padding-bottom: 0.25rem;">
                                        <span style="color: var(--color-text-muted);">Delivery Days</span>
                                        <strong
                                            style="color: <%= isFastestDelivery ? 'var(--color-accent)' : '#ffffff' %>; font-family: monospace;">
                                            <%= q.delivery_days %> days
                                        </strong>
                                    </div>

                                    <div
                                        style="display: flex; justify-content: space-between; border-bottom: 1px solid rgba(255,255,255,0.03); padding-bottom: 0.25rem;">
                                        <span style="color: var(--color-text-muted);">Warranty Duration</span>
                                        <span style="color: #ffffff;">
                                            <%= q.warranty_months %> months
                                        </span>
                                    </div>

                                    <div
                                        style="display: flex; justify-content: space-between; border-bottom: 1px solid rgba(255,255,255,0.03); padding-bottom: 0.25rem;">
                                        <span style="color: var(--color-text-muted);">Submission Date</span>
                                        <span style="color: #ffffff; font-family: monospace; font-size: 0.75rem;">
                                            <%= new Date(q.created_at).toLocaleDateString() %>
                                        </span>
                                    </div>

                                    <div
                                        style="display: flex; justify-content: space-between; border-bottom: 1px solid rgba(255,255,255,0.03); padding-bottom: 0.25rem;">
                                        <span style="color: var(--color-text-muted);">Bid Status</span>
                                        <span
                                            class="module-status-pill <%= q.status === 'Submitted' ? 'status-upcoming' : (q.status === 'Approved' ? 'status-active-badge' : '') %>"
                                            style="margin-top: 0; font-size: 0.65rem; padding: 0.1rem 0.4rem;">
                                            <%= q.status %>
                                        </span>
                                    </div>

                                    <% if (q.attachment) { %>
                                        <div
                                            style="display: flex; justify-content: space-between; border-bottom: 1px solid rgba(255,255,255,0.03); padding-bottom: 0.25rem;">
                                            <span style="color: var(--color-text-muted);">Technical Spec</span>
                                            <a href="/uploads/<%= q.attachment %>" target="_blank"
                                                style="color: var(--color-primary); font-weight: 600; text-decoration: none; display: inline-flex; align-items: center; gap: 0.25rem;">
                                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none"
                                                    stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                                    stroke-linejoin="round">
                                                    <path
                                                        d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48">
                                                    </path>
                                                </svg>
                                                Download Specs
                                            </a>
                                        </div>
                                        <% } %>

                                            <div style="margin-top: 0.5rem;">
                                                <span
                                                    style="color: var(--color-text-muted); display: block; margin-bottom: 0.15rem;">Technical
                                                    Remarks:</span>
                                                <p
                                                    style="color: var(--color-text-secondary); font-size: 0.75rem; background: rgba(0,0,0,0.15); padding: 0.5rem; border-radius: 6px; min-height: 50px; line-height: 1.4;">
                                                    <%= q.remarks || 'No remarks provided.' %>
                                                </p>
                                            </div>
                                </div>

                                <!-- ROUTING CONTROLS (Only visible if rfq is published/open and quote is submitted) -->
                                <% if (rfq.status==='Published' && q.status==='Submitted' ) { %>
                                    <div
                                        style="margin-top: 1.5rem; padding-top: 1rem; border-top: 1px solid rgba(255,255,255,0.05);">
                                        <form class="approval-route-form" data-rfq="<%= rfq.id %>"
                                            data-quote="<%= q.id %>"
                                            style="display: flex; flex-direction: column; gap: 0.5rem;">
                                            <label style="font-size: 0.75rem; color: var(--color-text-muted);">Assign
                                                Approving Manager:</label>
                                            <select name="assigned_to" class="form-control"
                                                style="font-size: 0.8rem; padding: 0.4rem;" required>
                                                <option value="" disabled selected>Select manager</option>
                                                <% managers.forEach(m=> { %>
                                                    <option value="<%= m.id %>">
                                                        <%= m.name %> (<%= m.email %>)
                                                    </option>
                                                    <% }) %>
                                            </select>
                                            <button type="submit" class="btn btn-primary btn-glow"
                                                style="padding: 0.45rem; font-size: 0.75rem; border-radius: 8px; width: 100%;">
                                                Route for Approval
                                            </button>
                                        </form>
                                    </div>
                                    <% } %>

                                        <!-- PURCHASE ORDER CONTROLS (Only visible if quote is approved) -->
                                        <% if (q.status==='Approved' ) { %>
                                            <div
                                                style="margin-top: 1.5rem; padding-top: 1rem; border-top: 1px solid rgba(255,255,255,0.05); text-align: center;">
                                                <% if (q.po_id) { %>
                                                    <a href="/procurement/po/<%= q.po_id %>" class="btn btn-secondary"
                                                        style="padding: 0.5rem 1rem; font-size: 0.8rem; border-radius: 8px; display: inline-flex; align-items: center; gap: 0.25rem; width: 100%; justify-content: center; background: rgba(99, 102, 241, 0.1); border-color: rgba(99, 102, 241, 0.25); color: #818cf8;">
                                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                                                            stroke="currentColor" stroke-width="2">
                                                            <path
                                                                d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z">
                                                            </path>
                                                            <polyline points="14 2 14 8 20 8"></polyline>
                                                            <line x1="16" y1="13" x2="8" y2="13"></line>
                                                            <line x1="16" y1="17" x2="8" y2="17"></line>
                                                            <polyline points="10 9 9 9 8 9"></polyline>
                                                        </svg>
                                                        View PO: <%= q.po_number %>
                                                    </a>
                                                    <% } else { %>
                                                        <form method="POST"
                                                            action="/procurement/po/generate/<%= q.id %>"
                                                            style="display: flex; flex-direction: column; gap: 0.5rem;">
                                                            <button type="submit" class="btn btn-primary btn-glow"
                                                                style="padding: 0.5rem 1rem; font-size: 0.8rem; border-radius: 8px; width: 100%; display: inline-flex; align-items: center; gap: 0.25rem; justify-content: center; background: linear-gradient(135deg, #10b981, #059669); box-shadow: 0 4px 20px rgba(16, 185, 129, 0.2);">
                                                                <svg width="14" height="14" viewBox="0 0 24 24"
                                                                    fill="none" stroke="currentColor" stroke-width="2">
                                                                    <path
                                                                        d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z">
                                                                    </path>
                                                                    <polyline points="14 2 14 8 20 8"></polyline>
                                                                    <line x1="12" y1="18" x2="12" y2="12"></line>
                                                                    <line x1="9" y1="15" x2="15" y2="15"></line>
                                                                </svg>
                                                                Generate Purchase Order
                                                            </button>
                                                        </form>
                                                        <% } %>
                                            </div>
                                            <% } %>
                            </div>
                            <% }) %>
                </div>
                <% } %>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const approvalForms = document.querySelectorAll('.approval-route-form');
            const alertContainer = document.getElementById('alert-container');

            approvalForms.forEach(form => {
                form.addEventListener('submit', async (e) => {
                    e.preventDefault();

                    const rfq_id = parseInt(form.getAttribute('data-rfq'), 10);
                    const quotation_id = parseInt(form.getAttribute('data-quote'), 10);
                    const assigned_to = parseInt(form.querySelector('select[name="assigned_to"]').value, 10);
                    const submitBtn = form.querySelector('button[type="submit"]');

                    if (!assigned_to) {
                        alert('Please select a manager.');
                        return;
                    }

                    submitBtn.disabled = true;
                    submitBtn.textContent = 'Routing quote...';

                    try {
                        const response = await fetch('/procurement/rfqs/request-approval', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ rfq_id, quotation_id, assigned_to })
                        });

                        const result = await response.json();

                        if (response.ok && result.success) {
                            alertContainer.innerHTML = `
                            <div class="alert-banner alert-banner-success" style="margin-bottom: 1.5rem;">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                                <span>${result.message}</span>
                            </div>
                        `;
                            setTimeout(() => {
                                window.location.reload();
                            }, 1500);
                        } else {
                            alert(result.message || 'Error routing quote.');
                            submitBtn.disabled = false;
                            submitBtn.textContent = 'Route for Approval';
                        }
                    } catch (err) {
                        console.error(err);
                        alert('Network connection error.');
                        submitBtn.disabled = false;
                        submitBtn.textContent = 'Route for Approval';
                    }
                });
            });
        });
    </script>

    <%- include('../partials/footer') %>