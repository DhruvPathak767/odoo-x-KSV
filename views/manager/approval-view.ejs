<%- include('../partials/header') %>

<div style="margin-bottom: 2rem;">
    <a href="/manager/approvals" style="color: var(--color-primary); font-size: 0.9rem; display: inline-flex; align-items: center; gap: 0.25rem; margin-bottom: 0.75rem;">
        &larr; Back to Approvals List
    </a>
    <h1 style="font-size: 2.2rem; margin-bottom: 0.5rem;">Cost Evaluation Panel</h1>
    <p style="color: var(--color-text-secondary);">Review supplier quotation proposal for RFQ: <strong><%= approval.rfq_title %></strong></p>
</div>

<div style="display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 2rem; align-items: start;">
    <!-- LEFT: RFQ REQUIREMENTS & ITEMS -->
    <div style="display: flex; flex-direction: column; gap: 2rem;">
        <div class="glass-card" style="padding: 2rem;">
            <h3 style="font-size: 1.2rem; border-bottom: 1px solid rgba(255,255,255,0.08); padding-bottom: 0.5rem; margin-bottom: 1rem; color: var(--color-primary);">RFQ Description</h3>
            <p style="color: var(--color-text-secondary); line-height: 1.6; font-size: 0.95rem; white-space: pre-line;"><%= approval.rfq_desc %></p>
            
            <div style="margin-top: 1.5rem; display: flex; gap: 2rem; flex-wrap: wrap;">
                <div style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.04); padding: 0.75rem 1.25rem; border-radius: 10px;">
                    <span style="font-size: 0.7rem; color: var(--color-text-muted); display: block; text-transform: uppercase;">Allocated Budget</span>
                    <strong style="color: #ffffff; font-family: monospace; font-size: 0.95rem;">$<%= parseFloat(approval.rfq_budget).toLocaleString() %></strong>
                </div>
                <% if (approval.rfq_attachment) { %>
                <div style="background: rgba(99,102,241,0.05); border: 1px solid rgba(99,102,241,0.2); padding: 0.75rem 1.25rem; border-radius: 10px;">
                    <span style="font-size: 0.7rem; color: var(--color-text-muted); display: block; text-transform: uppercase;">RFQ Guidelines Document</span>
                    <a href="/uploads/<%= approval.rfq_attachment %>" target="_blank" style="color: var(--color-primary); font-size: 0.95rem; font-weight: 600; text-decoration: none; display: inline-flex; align-items: center; gap: 0.25rem; margin-top: 0.15rem;">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"></path></svg>
                        Download SOW
                    </a>
                </div>
                <% } %>
            </div>
        </div>

        <div class="glass-card" style="padding: 2rem;">
            <h3 style="font-size: 1.2rem; border-bottom: 1px solid rgba(255,255,255,0.08); padding-bottom: 0.5rem; margin-bottom: 1rem; color: var(--color-primary);">RFQ Required Line Items</h3>
            <div style="overflow-x: auto;">
                <table style="width: 100%; border-collapse: collapse; text-align: left; font-size: 0.9rem;">
                    <thead>
                        <tr style="border-bottom: 1px solid rgba(255,255,255,0.06); color: var(--color-text-muted);">
                            <th style="padding: 0.75rem 0.5rem;">Item Description</th>
                            <th style="padding: 0.75rem 0.5rem; text-align: center;">Required Quantity</th>
                            <th style="padding: 0.75rem 0.5rem; text-align: right;">Target Unit Price</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% items.forEach(item => { %>
                            <tr style="border-bottom: 1px solid rgba(255,255,255,0.03);">
                                <td style="padding: 0.75rem 0.5rem;">
                                    <strong style="color: #ffffff;"><%= item.item_name %></strong>
                                </td>
                                <td style="padding: 0.75rem 0.5rem; text-align: center;"><%= item.quantity %></td>
                                <td style="padding: 0.75rem 0.5rem; text-align: right; font-family: monospace;">
                                    <%= item.target_price ? '$' + parseFloat(item.target_price).toLocaleString() : 'N/A' %>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- RIGHT: VENDOR PROPOSAL & MANAGER DECISION -->
    <div style="display: flex; flex-direction: column; gap: 2rem;">
        <!-- Vendor Quote Details -->
        <div class="glass-card" style="padding: 2rem;">
            <h3 style="font-size: 1.2rem; border-bottom: 1px solid rgba(255,255,255,0.08); padding-bottom: 0.5rem; margin-bottom: 1.25rem; color: var(--color-primary);">Supplier Proposal Details</h3>
            
            <div style="display: flex; flex-direction: column; gap: 0.85rem; font-size: 0.9rem; margin-bottom: 1.5rem;">
                <div style="display: flex; justify-content: space-between; border-bottom: 1px solid rgba(255,255,255,0.03); padding-bottom: 0.35rem;">
                    <span style="color: var(--color-text-muted);">Supplier Name</span>
                    <strong style="color: #ffffff;"><%= approval.vendor_name %></strong>
                </div>
                <div style="display: flex; justify-content: space-between; border-bottom: 1px solid rgba(255,255,255,0.03); padding-bottom: 0.35rem;">
                    <span style="color: var(--color-text-muted);">Supplier Rating</span>
                    <strong style="color: #fbbf24;">&starf; <%= approval.vendor_rating %> / 5.0</strong>
                </div>
                <div style="display: flex; justify-content: space-between; border-bottom: 1px solid rgba(255,255,255,0.03); padding-bottom: 0.35rem;">
                    <span style="color: var(--color-text-muted);">Proposed Price</span>
                    <strong style="color: var(--color-primary); font-family: monospace; font-size: 1.05rem;">$<%= parseFloat(approval.quote_price).toLocaleString() %></strong>
                </div>
                <div style="display: flex; justify-content: space-between; border-bottom: 1px solid rgba(255,255,255,0.03); padding-bottom: 0.35rem;">
                    <span style="color: var(--color-text-muted);">Delivery Timeline</span>
                    <strong style="color: #ffffff; font-family: monospace;"><%= approval.delivery_days %> days</strong>
                </div>
                <div style="display: flex; justify-content: space-between; border-bottom: 1px solid rgba(255,255,255,0.03); padding-bottom: 0.35rem;">
                    <span style="color: var(--color-text-muted);">Warranty Duration</span>
                    <span style="color: #ffffff;"><%= approval.warranty_months %> months</span>
                </div>
                <% if (approval.quote_attachment) { %>
                <div style="display: flex; justify-content: space-between; border-bottom: 1px solid rgba(255,255,255,0.03); padding-bottom: 0.35rem;">
                    <span style="color: var(--color-text-muted);">Technical Proposal</span>
                    <a href="/uploads/<%= approval.quote_attachment %>" target="_blank" style="color: var(--color-primary); font-weight: 600; text-decoration: none; display: inline-flex; align-items: center; gap: 0.25rem;">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"></path></svg>
                        Download PDF
                    </a>
                </div>
                <% } %>
            </div>

            <div>
                <span style="color: var(--color-text-muted); display: block; font-size: 0.85rem; margin-bottom: 0.25rem;">Supplier Remarks:</span>
                <p style="color: var(--color-text-secondary); font-size: 0.8rem; background: rgba(0,0,0,0.15); padding: 0.75rem; border-radius: 8px; line-height: 1.4;"><%= approval.quote_remarks || 'No remarks provided.' %></p>
            </div>
        </div>

        <!-- Manager Decision Form -->
        <div class="glass-card" style="padding: 2rem;">
            <h3 style="font-size: 1.2rem; border-bottom: 1px solid rgba(255,255,255,0.08); padding-bottom: 0.5rem; margin-bottom: 1.25rem; color: var(--color-primary);">Executive Decision</h3>
            
            <div id="alert-container"></div>

            <form class="auth-form" id="decision-form" method="POST" action="/manager/approvals/<%= approval.id %>/decision" style="gap: 1.25rem;">
                <div class="form-group">
                    <label for="remarks" class="form-label">Review Audit Remarks / Feedback</label>
                    <textarea id="remarks" name="remarks" class="form-control" rows="4" placeholder="Explain the rationale for approval or rejection..."></textarea>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 1rem;">
                    <button type="button" class="btn btn-secondary decision-btn" data-decision="Rejected" style="background: rgba(239, 68, 68, 0.08); border-color: rgba(239, 68, 68, 0.25); color: #f87171;">
                        Reject Proposal
                    </button>
                    <button type="button" class="btn btn-primary decision-btn" data-decision="Approved" style="background: linear-gradient(135deg, #10b981, #059669); box-shadow: 0 4px 20px rgba(16, 185, 129, 0.2);">
                        Approve Proposal
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const decisionBtns = document.querySelectorAll('.decision-btn');
        const decisionForm = document.getElementById('decision-form');
        const alertContainer = document.getElementById('alert-container');

        const showAlert = (message, type = 'error') => {
            alertContainer.innerHTML = `
                <div class="alert-banner alert-banner-${type}">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
                    <span>${message}</span>
                </div>
            `;
        };

        decisionBtns.forEach(btn => {
            btn.addEventListener('click', async () => {
                const status = btn.getAttribute('data-decision');
                const remarks = document.getElementById('remarks').value.trim();

                decisionBtns.forEach(b => b.disabled = true);
                btn.textContent = status === 'Approved' ? 'Approving...' : 'Rejecting...';

                try {
                    const response = await fetch(decisionForm.getAttribute('action'), {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ status, remarks })
                    });

                    const result = await response.json();

                    if (response.ok && result.success) {
                        showAlert(result.message, 'success');
                        setTimeout(() => {
                            window.location.href = result.redirectUrl || '/manager/approvals';
                        }, 1500);
                    } else {
                        showAlert(result.message || 'Error saving decision.', 'error');
                        decisionBtns.forEach(b => {
                            b.disabled = false;
                            b.textContent = b.getAttribute('data-decision') === 'Approved' ? 'Approve Proposal' : 'Reject Proposal';
                        });
                    }
                } catch (err) {
                    console.error(err);
                    showAlert('Network error. Check connection.', 'error');
                    decisionBtns.forEach(b => {
                        b.disabled = false;
                        b.textContent = b.getAttribute('data-decision') === 'Approved' ? 'Approve Proposal' : 'Reject Proposal';
                    });
                }
            });
        });
    });
</script>

<%- include('../partials/footer') %>
